        fused=True,
    )
    optimizers: list[torch.optim.Optimizer] = [optimizer_tok, optimizer_muon, optimizer_scalar]
    if head_params:
        optimizer_head = torch.optim.Adam(
            [{"params": head_params, "lr": config.train.head_lr, "base_lr": config.train.head_lr}],
            betas=(config.train.beta1, config.train.beta2),
            eps=config.train.adam_eps,
            fused=True,
        )
        optimizers.insert(1, optimizer_head)

    log0(f"model_params:{sum(p.numel() for p in base_model.parameters())}")
    log0(f"param_breakdown:{json.dumps(base_model.parameter_breakdown(), sort_keys=True)}")
    log0(f"world_size:{world_size} grad_accum_steps:{grad_accum_steps}")
    log0(f"flash_attn_3_loaded:{core_module.flash_attn_3_func is not None}")
    log0("sdp_backends:cudnn=False flash=True mem_efficient=False math=False")
    log0(
        f"train_batch_tokens:{config.train.train_batch_tokens} train_seq_len:{config.train.train_seq_len} "
        f"iterations:{config.train.iterations} warmup_steps:{config.train.warmup_steps} "
        f"max_wallclock_seconds:{config.train.max_wallclock_seconds:.3f}"
    )
    log0(
        f"activation_mode:{config.model.activation_mode} "
        f"export_quantizer:{config.export.export_quantizer} "
        f"ttt_optimizer:{config.eval.ttt_optimizer}"
    )
    log0(
        f"ngram_eval:enabled:{config.eval.ngram_eval_enabled} "
        f"two_pass:{config.eval.ngram_two_pass_enabled} "
        f"policy:{config.eval.ngram_two_pass_policy} "
        f"rescore_chunks:{config.eval.ngram_two_pass_rescore_chunks} "
        f"min_chunk_index:{config.eval.ngram_two_pass_min_chunk_index}"
    )
    log0(
        f"muon:banking_enabled:{config.train.muon_banking_enabled} "
        f"bank_min_tensors:{config.train.muon_bank_min_tensors}"
    )
    if master_process:
        log0(f"muon_banks:{json.dumps(optimizer_muon.describe_banks(), sort_keys=True)}", console=False)
    log0(
        f"moonshot lower_replace_layers:{config.model.lower_replace_layers} "
        f"local_shared_blocks:{config.model.local_shared_blocks} "
        f"use_unet_skips:{config.model.use_unet_skips}"
    )
    log0(f"seed:{config.train.seed}")

    shard_order = None
    if config.train.shard_order == "perplexity" and device.type == "cuda":
        log0("shard_order:computing perplexity ranking...")
        shard_order = core_module.rank_shards_by_perplexity(
            config.data.train_glob, base_model, device, n_tokens=4096, seq_len=min(512, config.train.train_seq_len),
        )
        log0(f"shard_order:ranked {len(shard_order)} shards by perplexity")
    train_loader = DistributedTokenLoader(config.data.train_glob, rank, world_size, device, file_order=shard_order)

    def zero_grad_all() -> None:
        for optimizer in optimizers:
            optimizer.zero_grad(set_to_none=True)

    if config.train.warmup_steps > 0:
        initial_model_state = {name: tensor.detach().cpu().clone() for name, tensor in base_model.state_dict().items()}
        initial_optimizer_states = [copy.deepcopy(optimizer.state_dict()) for optimizer in optimizers]
        model.train()
        for warmup_step in range(config.train.warmup_steps):
            zero_grad_all()
            for micro_step in range(grad_accum_steps):
                if distributed:
                    model.require_backward_grad_sync = micro_step == grad_accum_steps - 1
                x, y = train_loader.next_batch(
                    config.train.train_batch_tokens,
                    config.train.train_seq_len,
                    grad_accum_steps,
                )
                with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=True):
                    loss = model(x, y)
                (loss * grad_scale).backward()
            for optimizer in optimizers:
                optimizer.step()
            zero_grad_all()
            if config.train.warmup_steps <= 20 or warmup_step + 1 == config.train.warmup_steps:
                log0(f"warmup_step:{warmup_step + 1}/{config.train.warmup_steps}")
        base_model.load_state_dict(initial_model_state, strict=True)
        for optimizer, state in zip(optimizers, initial_optimizer_states, strict=True):
            optimizer.load_state_dict(state)
        zero_grad_all()
        if distributed:
            model.require_backward_grad_sync = True
        train_loader = DistributedTokenLoader(config.data.train_glob, rank, world_size, device, file_order=shard_order)

    ema_state = {name: tensor.detach().float().clone() for name, tensor in base_model.state_dict().items()}
    multi_ema_states = [
        {name: tensor.detach().float().clone() for name, tensor in base_model.state_dict().items()}
        for _ in config.train.multi_ema_decays
    ]
    swa_state: dict[str, Tensor] | None = None
    swa_count = 0
    sample_probe_batch: torch.Tensor | None = None
    qat_runtime_blocked = False
    training_time_ms = 0.0
    stop_after_step: int | None = None
    phase_timings: dict[str, Any] = {
        "diagnostic_eval_ms": 0.0,
        "quantize_ms": 0.0,
        "serialize_ms": 0.0,
        "roundtrip_eval_ms": 0.0,
        "sliding_eval_ms": 0.0,
        "skipped": {
            "diagnostic_eval": bool(config.train.skip_diagnostic_eval),
            "export": bool(config.train.skip_export),
            "roundtrip_eval": bool(config.train.skip_export or config.train.skip_roundtrip_eval),
            "sliding_eval": bool(config.train.skip_export or config.train.skip_sliding_eval),
        },
    }
    torch.cuda.synchronize()
    t0 = time.perf_counter()

    step = 0
    while True:
        last_step = step == config.train.iterations or (stop_after_step is not None and step >= stop_after_step)
        should_validate = last_step or (
            config.train.val_loss_every > 0 and step % config.train.val_loss_every == 0
        )
        if should_validate:
            torch.cuda.synchronize()
            training_time_ms += 1000.0 * (time.perf_counter() - t0)
            result = eval_standard(
                config,
                model,
                rank,
                world_size,
                device,
                grad_accum_steps,
                val_tokens,
                luts,
                eval_seq_len=config.eval.eval_seq_len,
            )
            log0(
                f"step:{step}/{config.train.iterations} val_loss:{result.val_loss:.4f} "
                f"val_bpb:{result.val_bpb:.4f} train_time:{training_time_ms:.0f}ms "
                f"step_avg:{training_time_ms / max(step, 1):.2f}ms"
            )
            torch.cuda.synchronize()
            t0 = time.perf_counter()

        if last_step:
            if stop_after_step is not None and step < config.train.iterations:
                log0(
                    f"stopping_early: wallclock_cap train_time:{training_time_ms:.0f}ms "
                    f"step:{step}/{config.train.iterations}"
                )
            break

        elapsed_ms = training_time_ms + 1000.0 * (time.perf_counter() - t0)
        scale = _lr_mul(config, step, elapsed_ms)
        if (
            config.train.qat_mode != "off"
            and config.train.late_qat_threshold > 0
            and scale < config.train.late_qat_threshold
            and not CastedLinear._qat_enabled
            and not qat_runtime_blocked
        ):
            if sample_probe_batch is not None:
                probe = probe_qat_activation(base_model, sample_probe_batch)
                runtime_probe = probe_qat_runtime(model, sample_probe_batch)
                log0(f"late_qat_probe:{json.dumps(probe, sort_keys=True)}")
                log0(f"late_qat_runtime_probe:{json.dumps(runtime_probe, sort_keys=True)}")
                if config.train.enable_compile and runtime_probe["runtime_loss_abs_diff"] == 0.0:
                    log0(f"late_qat:compile_blocks_qat disabling_compile_for_qat mode:{config.train.qat_mode}")
                    # Unwrap to base_model (skip DDP re-wrap to avoid NCCL state conflict)
                    model = base_model
                CastedLinear._qat_enabled = True
                log0(f"late_qat:enabled step:{step} scale:{scale:.4f} mode:{config.train.qat_mode}")
            else:
                CastedLinear._qat_enabled = True
                log0(f"late_qat:enabled step:{step} scale:{scale:.4f} mode:{config.train.qat_mode}")
        if CastedLinear._qat_mode == "soft_round" and CastedLinear._qat_enabled:
            qat_progress = max(0.0, 1.0 - scale / max(config.train.late_qat_threshold, 0.01))
            CastedLinear._soft_round_alpha = 1.0 + 15.0 * qat_progress
        zero_grad_all()
        train_loss = torch.zeros((), device=device)
        for micro_step in range(grad_accum_steps):
            if distributed:
                model.require_backward_grad_sync = micro_step == grad_accum_steps - 1
            effective_batch_tokens = config.train.train_batch_tokens
            if config.train.batch_warmup_steps > 0 and step < config.train.batch_warmup_steps:
                warmup_frac = config.train.batch_warmup_start_fraction + (
                    1.0 - config.train.batch_warmup_start_fraction
                ) * step / config.train.batch_warmup_steps
                effective_batch_tokens = max(
                    int(config.train.train_batch_tokens * warmup_frac),
                    config.train.train_seq_len * grad_accum_steps * world_size,
                )
            x, y = train_loader.next_batch(
                effective_batch_tokens,
                config.train.train_seq_len,
                grad_accum_steps,
            )
            if sample_probe_batch is None:
                sample_probe_batch = x[:1].detach()
            with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=True):
                loss = model(x, y)
            train_loss += loss.detach()
            (loss * grad_scale).backward()
        train_loss /= grad_accum_steps
        frac = min(step / config.train.muon_momentum_warmup_steps, 1.0) if config.train.muon_momentum_warmup_steps > 0 else 1.0
        muon_momentum = (
            (1.0 - frac) * config.train.muon_momentum_warmup_start + frac * config.train.muon_momentum
        )
        for group in optimizer_muon.param_groups:
            group["momentum"] = muon_momentum
        for optimizer in optimizers:
            for group in optimizer.param_groups:
                group["lr"] = group["base_lr"] * scale
        if config.train.grad_clip_norm > 0:
            torch.nn.utils.clip_grad_norm_(base_model.parameters(), config.train.grad_clip_norm)
        for optimizer in optimizers:
            optimizer.step()
        zero_grad_all()

        if config.train.tanh_clip_scale > 0:
            with torch.no_grad():
                _s = config.train.tanh_clip_scale
                for p in matrix_params:
                    p.data.copy_(_s * torch.tanh(p.data / _s))

        if config.train.ema_enabled:
            with torch.no_grad():
                effective_decay = config.train.ema_decay
                if config.train.ema_warmup_style == "step_aware" and config.train.ema_warmup_steps > 0:
                    ema_step = step + 1
                    warmup_decay = ema_step / max(ema_step + config.train.ema_warmup_steps, 1)
                    effective_decay = min(config.train.ema_decay, warmup_decay)
                for name, tensor in base_model.state_dict().items():
                    cpu_val = tensor.detach().float()
                    ema_state[name].mul_(effective_decay).add_(cpu_val, alpha=1.0 - effective_decay)
                    for ema_idx, extra_decay in enumerate(config.train.multi_ema_decays):
                        ed = extra_decay
                        if config.train.ema_warmup_style == "step_aware" and config.train.ema_warmup_steps > 0:
                            ed = min(extra_decay, (step + 1) / max(step + 1 + config.train.ema_warmup_steps, 1))
                        multi_ema_states[ema_idx][name].mul_(ed).add_(cpu_val, alpha=1.0 - ed)
        step += 1
        approx_training_time_ms = training_time_ms + 1000.0 * (time.perf_counter() - t0)
        if config.train.swa_enabled and scale < config.train.swa_start_scale and step % config.train.swa_every == 0:
            if swa_state is None:
                swa_state = {name: tensor.detach().cpu().clone() for name, tensor in base_model.state_dict().items()}
                swa_count = 1
                log0(f"swa:start step:{step}")
            else:
                for name, tensor in base_model.state_dict().items():
                    swa_state[name] += tensor.detach().cpu()
                swa_count += 1
        should_log_train = (
            config.train.train_log_every > 0
            and (step <= 10 or step % config.train.train_log_every == 0 or stop_after_step is not None)
        )
        if should_log_train:
            log0(
                f"step:{step}/{config.train.iterations} train_loss:{train_loss.item():.4f} "
                f"train_time:{approx_training_time_ms:.0f}ms step_avg:{approx_training_time_ms / step:.2f}ms"
            )
        reached_cap = (
            config.train.max_wallclock_seconds > 0
            and approx_training_time_ms >= 1000.0 * config.train.max_wallclock_seconds
        )
        if distributed and config.train.max_wallclock_seconds > 0:
            reached_cap_tensor = torch.tensor(int(reached_cap), device=device)
            dist.all_reduce(reached_cap_tensor, op=dist.ReduceOp.MAX)
            reached_cap = bool(reached_cap_tensor.item())
        if stop_after_step is None and reached_cap:
            stop_after_step = step

    log0(
        f"peak memory allocated: {torch.cuda.max_memory_allocated() // 1024 // 1024} MiB "
        f"reserved: {torch.cuda.max_memory_reserved() // 1024 // 1024} MiB"
    )

    if config.train.ema_enabled:
        candidates = [(config.train.ema_decay, ema_state)] + list(zip(config.train.multi_ema_decays, multi_ema_states))
        best_bpb, best_decay, best_state = float("inf"), config.train.ema_decay, ema_state
        if len(candidates) > 1:
            small_val = val_tokens[: min(64 * config.eval.eval_seq_len + 1, val_tokens.numel())]
            for decay, state in candidates:
                base_model.load_state_dict(
                    {n: t.to(dtype=base_model.state_dict()[n].dtype) for n, t in state.items()}, strict=True
                )
                r = eval_standard(
                    config, model, rank, world_size, device, grad_accum_steps, small_val, luts,
                    eval_seq_len=config.eval.eval_seq_len,
                )
                log0(f"multi_ema_candidate decay:{decay:.4f} val_bpb:{r.val_bpb:.4f}")
                if r.val_bpb < best_bpb:
                    best_bpb, best_decay, best_state = r.val_bpb, decay, state
        log0(f"ema:applying best EMA (decay={best_decay:.4f} bpb={best_bpb:.4f})")
        base_model.load_state_dict(
            {n: t.to(dtype=base_model.state_dict()[n].dtype) for n, t in best_state.items()}, strict=True
        )
    elif config.train.swa_enabled and swa_state is not None and swa_count > 0:
        log0(f"swa:applying checkpoints:{swa_count}")
        avg_state = {name: tensor.div(swa_count).to(dtype=base_model.state_dict()[name].dtype) for name, tensor in swa_state.items()}
        base_model.load_state_dict(avg_state, strict=True)

    if config.train.save_post_train_checkpoint and master_process:
        checkpoint_state = {name: tensor.detach().cpu() for name, tensor in base_model.artifact_state_dict().items()}
        torch.save(checkpoint_state, config.train.post_train_checkpoint_name)
        log0(
            f"Saved post-train checkpoint: {config.train.post_train_checkpoint_name} "
            f"({Path(config.train.post_train_checkpoint_name).stat().st_size} bytes)"
        )

    if config.train.skip_diagnostic_eval:
        log0("DIAGNOSTIC post_average skipped")
    else:
        diag = _measure_phase_ms(
            phase_timings,
            "diagnostic_eval_ms",
            lambda: eval_standard(
                config,
                model,
                rank,
                world_size,
                device,
                grad_accum_steps,
                val_tokens,
                luts,
                eval_seq_len=config.eval.eval_seq_len,
            ),
        )
        log0(
            f"DIAGNOSTIC post_average val_loss:{diag.val_loss:.4f} val_bpb:{diag.val_bpb:.4f} "
            f"eval_time:{diag.eval_ms:.0f}ms"
        )

    forced_skip_roundtrip = config.train.skip_export or config.train.skip_roundtrip_eval
    forced_skip_sliding = config.train.skip_export or config.train.skip_sliding_eval or config.eval.ngram_eval_enabled
    state_dict = base_model.artifact_state_dict()
    gptq_hessians: dict[str, Any] | None = None
    if not config.train.skip_export and config.export.export_quantizer.startswith("full_gptq"):
        calib_batches = config.export.gptq_calib_batches
        calib_batch_tokens = config.export.gptq_calib_batch_tokens
        calib_seq_len = config.export.gptq_calib_seq_len or config.train.train_seq_len
        log0(
            f"gptq:calibrating hessians batches:{calib_batches} "
            f"batch_tokens:{calib_batch_tokens} seq_len:{calib_seq_len}"
        )
        t_cal = time.perf_counter()
        gptq_hessians = core_module.gptq_calibrate(
            base_model,
            config.data.train_glob,
            device,
            n_samples=calib_batches,
            seq_len=calib_seq_len,
            batch_tokens=calib_batch_tokens,
            rank=rank,
            world_size=world_size,
        )
        log0(f"gptq:calibrated {len(gptq_hessians)} layers in {time.perf_counter() - t_cal:.1f}s")
    artifact_stats_rt: dict[str, Any] | None = None
    compiled_eval_model: torch.nn.Module | None = None
    roundtrip = None
    sliding = None

    def ensure_export_eval_model() -> tuple[torch.nn.Module, dict[str, Any]]:
        nonlocal compiled_eval_model, artifact_stats_rt
        if compiled_eval_model is None or artifact_stats_rt is None:
            with open(config.export.export_name, "rb") as handle:
                export_blob_disk = handle.read()
            payload_rt, metadata_rt, artifact_stats_rt_local = deserialize_export_blob(export_blob_disk, config.export)
            roundtrip_state = dequantize_export(payload_rt, metadata_rt, state_dict)
            eval_model = ParameterGolfModel.from_exported_state(roundtrip_state, config.model, config.data.vocab_size, device)
            compiled_eval_model = eval_model
            if config.train.enable_compile:
                compiled_eval_model = torch.compile(eval_model, dynamic=False, fullgraph=True)
            artifact_stats_rt = artifact_stats_rt_local
        return compiled_eval_model, artifact_stats_rt

    if config.train.skip_export:
        log0("export skipped")
        log0("final_research_export_roundtrip skipped")
        log0("final_research_export_sliding skipped")
    else:
        def _quantize_with_grid_search():
            import copy as _copy
            from concurrent.futures import ThreadPoolExecutor as _TPE

            base_refine = config.export.gptq_refine_steps
            base_block = config.export.gptq_block_size
            base_damp = config.export.gptq_damp_percent
            if config.export.export_quantizer.startswith("full_gptq") and gptq_hessians:
                smaller_block = max(32, base_block // 2)
                grid = [
                    (base_block, base_damp, base_refine),
                    (smaller_block, base_damp, base_refine),
                    (base_block, base_damp * 0.5, base_refine),
                    (smaller_block, base_damp * 0.5, base_refine),
                ]
            else:
                grid = [
                    (base_block, base_damp, base_refine),
                    (base_block, base_damp, base_refine + 2),
                    (base_block, base_damp * 0.5, base_refine),
                    (base_block, base_damp * 0.5, base_refine + 2),
                ]

            def _try(block_size: int, damp: float, refine: int):
                ec = _copy.deepcopy(config.export)
                ec.gptq_block_size = block_size
                ec.gptq_refine_steps = refine
                ec.gptq_damp_percent = damp
                p, m, s = quantize_for_export(state_dict, ec, hessians=gptq_hessians)
                mse = sum(v["mse"] for v in s["tensor_stats"].values())
                return block_size, refine, damp, p, m, s, mse

            best = None
            workers = min(len(grid), os.cpu_count() or 4)
            with _TPE(max_workers=workers) as pool:
                futs = [pool.submit(_try, b, d, r) for b, d, r in grid]
                for f in futs:
                    block_size, refine, damp, p, m, s, mse = f.result()
                    log0(f"export_grid block:{block_size} refine:{refine} damp:{damp:.4f} mse:{mse:.8f}")
                    if best is None or mse < best[-1]:
                        best = (p, m, s, mse)
            return best[0], best[1], best[2]

        payload, metadata, export_stats = _measure_phase_ms(
            phase_timings,
            "quantize_ms",
            _quantize_with_grid_search,
        )
        export_blob, compressed_stats = _measure_phase_ms(
            phase_timings,
            "serialize_ms",
            lambda: serialize_export_blob(payload, metadata, config.export),
        )
        export_stats.update(compressed_stats)
        export_stats["public_winner_ref"] = PUBLIC_WINNER_GIT_REF
        export_stats["public_winner_commit"] = PUBLIC_WINNER_COMMIT
        if master_process:
            log0(
                "gptq_quantize: "
                f"{export_stats.get('gptq_layers', 0)} GPTQ layers, "
                f"{export_stats.get('naive_layers', 0)} naive layers"
            )
            mixed_precision = export_stats.get("mixed_precision_params", {})
            if mixed_precision:
                log0(
                    "mixed_precision: "
                    f"{mixed_precision.get('int5', 0)} int5 params, "
                    f"{mixed_precision.get('int6', 0)} int6 params"
                )
        if master_process:
            with open(config.export.export_name, "wb") as handle:
                handle.write(export_blob)
            code_bytes = len(code.encode("utf-8"))
            log0(f"Serialized model research_export: {compressed_stats['artifact_bytes']} bytes")
            log0(f"Code size: {code_bytes} bytes")
            log0(f"Total submission size research_export: {compressed_stats['artifact_bytes'] + code_bytes} bytes")
            log0(f"artifact_stats:{json.dumps(export_stats, sort_keys=True)}", console=False)

        if distributed:
            dist.barrier()

        if forced_skip_roundtrip:
            log0("final_research_export_roundtrip skipped")
        else:
            artifact_stats_rt, roundtrip = _measure_phase_ms(
                phase_timings,
                "roundtrip_eval_ms",
                lambda: (
                    lambda model_and_stats: (
                        model_and_stats[1],
                        eval_standard(
                            config,
                            model_and_stats[0],
                            rank,
                            world_size,
                            device,
                            grad_accum_steps,
                            val_tokens,
                            luts,
                            eval_seq_len=config.eval.eval_seq_len,
                        ),
                    )
                )(ensure_export_eval_model()),
            )
            log0(
                f"final_research_export_roundtrip val_loss:{roundtrip.val_loss:.4f} "
                f"val_bpb:{roundtrip.val_bpb:.4f} eval_time:{roundtrip.eval_ms:.0f}ms"
            )

        if forced_skip_sliding:
            log0("final_research_export_sliding skipped")
        else:
            artifact_stats_rt, sliding = _measure_phase_ms(
                phase_timings,
                "sliding_eval_ms",
                lambda: (
                    lambda model_and_stats: (
                        model_and_stats[1],
                        eval_sliding(
                            config,
                            model_and_stats[0],
                            device,
                            val_tokens,
                            luts,
                            stride=config.eval.sliding_stride,
                            eval_seq_len=config.eval.eval_seq_len,
                        ),
                    )
                )(ensure_export_eval_model()),
            )
            log0(
                f"final_research_export_sliding val_loss:{sliding.val_loss:.4f} val_bpb:{sliding.val_bpb:.4f} "
                f"stride:{sliding.stride} eval_time:{sliding.eval_ms:.0f}ms"
            )

        if config.eval.doc_isolated and rank == 0:
            compiled_eval_model, _ = ensure_export_eval_model()
