def tensor_nbytes(t: Tensor) -> int:
    return int(t.numel()) * int(t.element_size())


def tensor_max_abs_error(a: Tensor, b: Tensor) -> float:
    if a.numel() == 0 and b.numel() == 0:
        return 0.0
    return float((a.float() - b.float()).abs().max().item())


def _compress_bytes(raw: bytes, config: ExportConfig) -> bytes:
    if config.normalized_compressor() == "lzma":
        return lzma.compress(raw, preset=6)
    if config.normalized_compressor() == "zstd" and zstd is not None:
        return zstd.ZstdCompressor(level=config.zstd_level).compress(raw)
    return zlib.compress(raw, 9)


def _decompress_bytes(blob: bytes, config: ExportConfig, compressor: str | None = None) -> bytes:
    preferred = (compressor or config.normalized_compressor()).strip().lower()
    if preferred == "lzma":
        candidates = ("lzma", "zstd", "zlib")
    elif preferred == "zstd":
        candidates = ("zstd", "zlib", "lzma")
    else:
        candidates = ("zlib", "zstd", "lzma")
    last_error: Exception | None = None
    for candidate in candidates:
        try:
            if candidate == "lzma":
                return lzma.decompress(blob)
            if candidate == "zstd":
                if zstd is None:
                    continue
                return zstd.ZstdDecompressor().decompress(blob)
            return zlib.decompress(blob)
        except Exception as exc:  # noqa: BLE001
            last_error = exc
    if last_error is not None:
        raise last_error
    raise RuntimeError("No decompressor available for export blob")


def zeropower_via_newtonschulz5(g: Tensor, steps: int = 10, eps: float = 1e-7) -> Tensor:
    a, b, c = (3.4445, -4.7750, 2.0315)
    was_2d = g.ndim == 2
    if was_2d:
        g = g.unsqueeze(0)
    x = g.bfloat16()
    x /= x.norm(dim=(-2, -1), keepdim=True) + eps
    transposed = g.size(-2) > g.size(-1)
    if transposed:
        x = x.mT
    for _ in range(steps):
        a_mat = x @ x.mT
        b_mat = b * a_mat + c * a_mat @ a_mat
        x = a * x + b_mat @ x
    if transposed:
        x = x.mT
    return x.squeeze(0) if was_2d else x


class Muon(torch.optim.Optimizer):
    def __init__(
        self,
        params,
        lr: float,
        momentum: float,
        backend_steps: int,
        nesterov: bool = True,
        weight_decay: float = 0.0,
        banking_enabled: bool = False,
        bank_min_tensors: int = 2,
    ):
        super().__init__(
            params,
            dict(
                lr=lr,
                momentum=momentum,
                backend_steps=backend_steps,
                nesterov=nesterov,
                weight_decay=weight_decay,
                banking_enabled=banking_enabled,
                bank_min_tensors=bank_min_tensors,
            ),
        )
        self._bank_summary_cache: list[dict[str, Any]] | None = None

    def describe_banks(self) -> list[dict[str, Any]]:
        if self._bank_summary_cache is not None:
            return self._bank_summary_cache
        summaries: list[dict[str, Any]] = []
        for group in self.param_groups:
            params = [p for p in group["params"] if p.ndim == 2]
            if not params:
                continue
            by_shape: dict[tuple[int, int], list[Tensor]] = defaultdict(list)
            for param in params:
                by_shape[tuple(int(dim) for dim in param.shape)].append(param)
            min_bank = int(group.get("bank_min_tensors", 2))
            banking_enabled = bool(group.get("banking_enabled", False))
            for shape, tensors in sorted(by_shape.items()):
                banked = banking_enabled and len(tensors) >= min_bank
                summaries.append(
                    {
                        "shape": list(shape),
                        "count": len(tensors),
                        "banked": banked,
                    }
                )
        self._bank_summary_cache = summaries
        return summaries

    def _active_params_with_offsets(self, params: list[Tensor]) -> tuple[list[tuple[int, Tensor]], dict[int, int], int]:
        active: list[tuple[int, Tensor]] = []
        offsets: dict[int, int] = {}
        curr = 0
        for idx, param in enumerate(params):
            if param.grad is None:
                continue
            active.append((idx, param))
            offsets[idx] = curr
            curr += int(param.numel())
        return active, offsets, curr

    def _group_active_params(
        self,
        active_params: list[tuple[int, Tensor]],
        *,
        banking_enabled: bool,
        bank_min_tensors: int,
    ) -> list[dict[str, Any]]:
        by_shape: dict[tuple[int, int], list[tuple[int, Tensor]]] = defaultdict(list)
        ordered_groups: list[dict[str, Any]] = []
        singleton_groups: list[tuple[int, Tensor]] = []
        for idx, param in active_params:
            if param.ndim != 2:
                singleton_groups.append((idx, param))
                continue
            by_shape[tuple(int(dim) for dim in param.shape)].append((idx, param))

        for shape, items in sorted(by_shape.items()):
            if banking_enabled and len(items) >= bank_min_tensors:
                ordered_groups.append({"shape": shape, "items": items, "banked": True})
            else:
                singleton_groups.extend(items)
        for idx, param in singleton_groups:
            ordered_groups.append({"shape": tuple(int(dim) for dim in param.shape), "items": [(idx, param)], "banked": False})
        return ordered_groups

    def _compute_group_updates(
        self,
        items: list[tuple[int, Tensor]],
        *,
        momentum: float,
        nesterov: bool,
        backend_steps: int,
        world_size: int,
        rank: int,
    ) -> dict[int, Tensor]:
        local_indices: list[int] = []
        grad_batch: list[Tensor] = []
        buf_batch: list[Tensor] = []
        for local_pos, (_, param) in enumerate(items):
            if local_pos % world_size != rank:
                continue
            grad = param.grad
            if grad is None:
                continue
            state = self.state[param]
            if "momentum_buffer" not in state:
                state["momentum_buffer"] = torch.zeros_like(grad)
            buf = state["momentum_buffer"]
            local_indices.append(local_pos)
            grad_batch.append(grad)
            buf_batch.append(buf)

        if not grad_batch:
            return {}

        grads = torch.stack([g.to(dtype=torch.bfloat16) for g in grad_batch], dim=0)
        bufs = torch.stack([b.to(dtype=torch.bfloat16) for b in buf_batch], dim=0)
        bufs.mul_(momentum).add_(grads)
        if nesterov:
            updates = grads.add(bufs, alpha=momentum)
        else:
            updates = bufs.clone()
        updates = zeropower_via_newtonschulz5(updates, steps=backend_steps)

        computed: dict[int, Tensor] = {}
        for batch_idx, local_pos in enumerate(local_indices):
            _, param = items[local_pos]
            self.state[param]["momentum_buffer"].copy_(bufs[batch_idx].to(dtype=param.dtype))
            computed[local_pos] = updates[batch_idx]
        return computed

    @torch.no_grad()
    def step(self, closure=None):
        loss = None
        if closure is not None:
            with torch.enable_grad():
                loss = closure()

        distributed = dist.is_available() and dist.is_initialized()
        world_size = dist.get_world_size() if distributed else 1
        rank = dist.get_rank() if distributed else 0

        for group in self.param_groups:
            params = group["params"]
            if not params:
                continue
            lr = group["lr"]
            momentum = group["momentum"]
            backend_steps = group["backend_steps"]
            nesterov = group["nesterov"]
            banking_enabled = bool(group.get("banking_enabled", False))
            bank_min_tensors = int(group.get("bank_min_tensors", 2))
            active_params, offsets, total_params = self._active_params_with_offsets(params)
            if total_params == 0:
                continue
            updates_flat = torch.zeros(total_params, device=params[0].device, dtype=torch.bfloat16)
            active_groups = self._group_active_params(
                active_params,
                banking_enabled=banking_enabled,
                bank_min_tensors=bank_min_tensors,
            )
            for group_meta in active_groups:
                computed = self._compute_group_updates(
                    group_meta["items"],
                    momentum=momentum,
                    nesterov=nesterov,
                    backend_steps=backend_steps,
                    world_size=world_size,
                    rank=rank,
                )
                for local_pos, update in computed.items():
                    param_idx, param = group_meta["items"][local_pos]
                    scale = max(1.0, float(param.size(0)) / max(float(param.size(1)), 1.0)) ** 0.5
                    start = offsets[param_idx]
                    updates_flat[start : start + param.numel()] = (update * scale).reshape(-1)
            if distributed:
                dist.all_reduce(updates_flat, op=dist.ReduceOp.SUM)

            weight_decay = group.get("weight_decay", 0.0)
            for param_idx, param in active_params:
                if weight_decay > 0:
                    param.data.mul_(1.0 - lr * weight_decay)
                start = offsets[param_idx]
                grad = updates_flat[start : start + param.numel()].view_as(param).to(dtype=param.dtype)
                param.add_(grad, alpha=-lr)
        return loss


def load_data_shard(path: Path) -> Tensor:
    header_bytes = 256 * np.dtype("<i4").itemsize
    token_bytes = np.dtype("<u2").itemsize
    header = np.fromfile(path, dtype="<i4", count=256)
    if header.size != 256 or int(header[0]) != DATAFILE_MAGIC or int(header[1]) != DATAFILE_VERSION:
        raise ValueError(f"Unexpected shard header for {path}")
    num_tokens = int(header[2])
    expected_size = header_bytes + num_tokens * token_bytes
    if path.stat().st_size != expected_size:
        raise ValueError(f"Shard size mismatch for {path}")
    tokens_np = np.fromfile(path, dtype="<u2", count=num_tokens, offset=header_bytes)
    if tokens_np.size != num_tokens:
        raise ValueError(f"Short read for {path}")
    return torch.from_numpy(tokens_np.astype(np.uint16, copy=False))


def rank_shards_by_perplexity(
    pattern: str,
    model: nn.Module,
    device: torch.device,
    n_tokens: int = 4096,
    seq_len: int = 512,
) -> list[Path]:
    """Rank training shards by model perplexity (easy → hard curriculum)."""
    files = [Path(p) for p in sorted(glob.glob(pattern))]
    if not files:
        return files
    losses: list[tuple[float, Path]] = []
    model.eval()
    with torch.no_grad():
        for path in files:
            tokens = load_data_shard(path)
            n = min(n_tokens, tokens.numel() - 1)
            if n < seq_len:
                losses.append((0.0, path))
                continue
            x = tokens[:n].to(device=device, dtype=torch.int64).reshape(-1, seq_len)
            y = tokens[1 : n + 1].to(device=device, dtype=torch.int64).reshape(-1, seq_len)
            with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                loss = model(x, y)
            losses.append((float(loss.item()), path))
    model.train()
    losses.sort(key=lambda t: t[0])
    return [path for _, path in losses]


class TokenStream:
    def __init__(self, pattern: str, file_order: list[Path] | None = None):
        self.files = file_order if file_order is not None else [Path(p) for p in sorted(glob.glob(pattern))]
        if not self.files:
            raise FileNotFoundError(f"No files found for pattern: {pattern}")
        self.file_idx = 0
        self.tokens = load_data_shard(self.files[0])
        self.pos = 0

    def _advance_file(self) -> None:
        self.file_idx = (self.file_idx + 1) % len(self.files)
        self.tokens = load_data_shard(self.files[self.file_idx])
        self.pos = 0

    def take(self, n: int) -> Tensor:
        chunks: list[Tensor] = []
        remaining = n
        while remaining > 0:
            if self.pos >= self.tokens.numel():
                self._advance_file()
            take = min(remaining, int(self.tokens.numel() - self.pos))
            chunks.append(self.tokens[self.pos : self.pos + take])
            self.pos += take
            remaining -= take
        return chunks[0] if len(chunks) == 1 else torch.cat(chunks, dim=0)


class DistributedTokenLoader:
    def __init__(self, pattern: str, rank: int, world_size: int, device: torch.device, file_order: list[Path] | None = None):
        self.stream = TokenStream(pattern, file_order=file_order)
        self.rank = rank
        self.world_size = world_size
        self.device = device
        self._prefetch_thread: threading.Thread | None = None
        self._prefetch_result: tuple[Tensor, Tensor] | None = None
        self._last_args: tuple[int, int, int] | None = None

    def _load_batch(self, global_tokens: int, seq_len: int, grad_accum_steps: int) -> tuple[Tensor, Tensor]:
        local_tokens = global_tokens // (self.world_size * grad_accum_steps)
        local_tokens = (local_tokens // seq_len) * seq_len
        if local_tokens <= 0:
            raise ValueError("Batch is too small for the configured sequence length")
        per_rank_span = local_tokens + 1
        chunk = self.stream.take(per_rank_span * self.world_size)
        start = self.rank * per_rank_span
        local = chunk[start : start + per_rank_span].to(dtype=torch.int64)
        x = local[:-1].reshape(-1, seq_len)
        y = local[1:].reshape(-1, seq_len)
        if self.device.type == "cuda":
            x = x.pin_memory()
            y = y.pin_memory()
        return x, y

    def _prefetch_worker(self, global_tokens: int, seq_len: int, grad_accum_steps: int) -> None:
        self._prefetch_result = self._load_batch(global_tokens, seq_len, grad_accum_steps)

    def next_batch(self, global_tokens: int, seq_len: int, grad_accum_steps: int) -> tuple[Tensor, Tensor]:
        args = (global_tokens, seq_len, grad_accum_steps)
        if self._prefetch_thread is not None:
            self._prefetch_thread.join()
            self._prefetch_thread = None
        if self._prefetch_result is not None and self._last_args == args:
            x, y = self._prefetch_result
            self._prefetch_result = None
        else:
            self._prefetch_result = None
            x, y = self._load_batch(*args)
        self._last_args = args
        self._prefetch_thread = threading.Thread(
            target=self._prefetch_worker, args=args, daemon=True
        )
        self._prefetch_thread.start()
        return x.to(self.device, non_blocking=True), y.to(self.device, non_blocking=True)


def build_sentencepiece_luts(
    sp: spm.SentencePieceProcessor,
    vocab_size: int,
    device: torch.device,
) -> tuple[Tensor, Tensor, Tensor]:
    sp_vocab_size = int(sp.vocab_size())
    table_size = max(sp_vocab_size, vocab_size)
    base_bytes = np.zeros((table_size,), dtype=np.int16)
    has_leading_space = np.zeros((table_size,), dtype=np.bool_)
    is_boundary_token = np.ones((table_size,), dtype=np.bool_)
    for token_id in range(sp_vocab_size):
        if sp.is_control(token_id) or sp.is_unknown(token_id) or sp.is_unused(token_id):
            continue
        is_boundary_token[token_id] = False
        if sp.is_byte(token_id):
            base_bytes[token_id] = 1
            continue
        piece = sp.id_to_piece(token_id)
        if piece.startswith("▁"):
            has_leading_space[token_id] = True
            piece = piece[1:]
        base_bytes[token_id] = len(piece.encode("utf-8"))
    return (
        torch.tensor(base_bytes, dtype=torch.int16, device=device),
        torch.tensor(has_leading_space, dtype=torch.bool, device=device),
        torch.tensor(is_boundary_token, dtype=torch.bool, device=device),
    )


def load_validation_tokens(pattern: str, seq_len: int, max_seqs: int = 0) -> Tensor:
    files = [Path(p) for p in sorted(glob.glob(pattern))]
    if not files:
        raise FileNotFoundError(f"No files found for pattern: {pattern}")
    tokens = torch.cat([load_data_shard(path) for path in files]).contiguous()
    if max_seqs < 0:
        raise ValueError(f"VAL_MAX_SEQS must be non-negative, got {max_seqs}")
    usable = ((tokens.numel() - 1) // seq_len) * seq_len
    if max_seqs > 0:
        usable = min(usable, max_seqs * seq_len)
    if usable <= 0:
        raise ValueError(f"Validation split is too short for seq_len={seq_len}")
    return tokens[: usable + 1]


def _score_token_bytes(prev_ids: Tensor, tgt_ids: Tensor, luts: tuple[Tensor, Tensor, Tensor]) -> Tensor:
    base_bytes_lut, has_leading_space_lut, is_boundary_token_lut = luts
    token_bytes = base_bytes_lut[tgt_ids].to(dtype=torch.int16)
    token_bytes += (has_leading_space_lut[tgt_ids] & ~is_boundary_token_lut[prev_ids]).to(dtype=torch.int16)
    return token_bytes


def _document_spans(tokens: Tensor, bos_id: int) -> list[tuple[int, int]]:
    starts = (tokens[:-1] == bos_id).nonzero(as_tuple=False).flatten().tolist()
    if not starts:
        return [(0, tokens.numel() - 1)]
    spans: list[tuple[int, int]] = []
    for idx, start in enumerate(starts):
        end = starts[idx + 1] if idx + 1 < len(starts) else tokens.numel() - 1
        if end - start > 1:
            spans.append((start, end))
    return spans


class RMSNorm(nn.Module):
    def __init__(self, eps: float | None = None):
        super().__init__()
        self.eps = eps

    def forward(self, x: Tensor) -> Tensor:
        return F.rms_norm(x, (x.size(-1),), eps=self.eps)


class CastedLinear(nn.Linear):
    _qat_enabled: bool = False
    _qat_mode: str = "ste"
    _soft_round_alpha: float = 1.0

    def forward(self, x: Tensor) -> Tensor:
        weight = self.weight.to(x.dtype)
        if CastedLinear._qat_enabled and self.training and weight.ndim == 2:
            with torch.no_grad():
                w32 = self.weight.float()
                row_max = w32.abs().amax(dim=1)
                scale = (row_max / 31.0).clamp_min(1.0 / 31.0)
                scaled = w32 / scale[:, None]
                if CastedLinear._qat_mode == "soft_round":
                    fl = torch.floor(scaled)
                    r = scaled - fl - 0.5
                    alpha = CastedLinear._soft_round_alpha
                    rounded = fl + 0.5 * torch.tanh(alpha * r) / (math.tanh(alpha / 2) + 1e-10) + 0.5
                else:
                    rounded = torch.round(scaled)
                weight_q = (torch.clamp(rounded, -32, 31) * scale[:, None]).to(x.dtype)
            weight = weight + (weight_q - weight).detach().clone()
        bias = self.bias.to(x.dtype) if self.bias is not None else None
        return F.linear(x, weight, bias)


def probe_qat_activation(model: nn.Module, sample_x: Tensor) -> dict[str, float]:
    was_training = model.training
    CastedLinear._qat_enabled = False
    model.train()
    with torch.no_grad():
        base_logits = model.forward_logits(sample_x)
    CastedLinear._qat_enabled = True
    with torch.no_grad():
        qat_logits = model.forward_logits(sample_x)
    if not was_training:
        model.eval()
    diff = (qat_logits - base_logits).abs()
    return {
        "probe_max_abs_diff": float(diff.max().item()),
        "probe_mean_abs_diff": float(diff.mean().item()),
    }


def probe_qat_runtime(model: nn.Module, sample_x: Tensor) -> dict[str, float]:
    was_training = model.training
    CastedLinear._qat_enabled = False
    model.train()
    with torch.no_grad():
        base_loss = model(sample_x, sample_x)
    CastedLinear._qat_enabled = True
    with torch.no_grad():
        qat_loss = model(sample_x, sample_x)
    CastedLinear._qat_enabled = False
    if not was_training:
        model.eval()
    return {
        "runtime_loss_abs_diff": float((qat_loss - base_loss).abs().item()),
        "runtime_loss_off": float(base_loss.item()),
        "runtime_loss_on": float(qat_loss.item()),
    }


def restore_low_dim_params_to_fp32(module: nn.Module) -> None:
    with torch.no_grad():
        for name, param in module.named_parameters():
            if param.ndim < 2 or any(pattern in name for pattern in CONTROL_NAME_PATTERNS):
                if param.dtype != torch.float32:
                    param.data = param.data.float()


class Rotary(nn.Module):
    def __init__(self, dim: int, base: float = 10000.0, train_seq_len: int = 1024, rope_dims: int = 0):
        super().__init__()
        self.dim = dim
        self.base = base
        self.train_seq_len = train_seq_len
        self.rope_dims = rope_dims if rope_dims > 0 else dim
        inv_freq = 1.0 / (base ** (torch.arange(0, self.rope_dims, 2, dtype=torch.float32) / self.rope_dims))
        self.register_buffer("inv_freq", inv_freq, persistent=False)
        self._seq_len_cached = 0
        self._cos_cached: Tensor | None = None
        self._sin_cached: Tensor | None = None

    def forward(self, seq_len: int, device: torch.device, dtype: torch.dtype) -> tuple[Tensor, Tensor]:
        if (
            self._cos_cached is None
            or self._sin_cached is None
            or self._seq_len_cached != seq_len
            or self._cos_cached.device != device
        ):
            rope_dims = self.rope_dims
            if seq_len > self.train_seq_len:
                scale = seq_len / self.train_seq_len
                new_base = self.base * (scale ** (rope_dims / (rope_dims - 2)))
                inv_freq = 1.0 / (
                    new_base ** (torch.arange(0, rope_dims, 2, dtype=torch.float32, device=device) / rope_dims)
                )
            else:
                inv_freq = self.inv_freq.to(device)
            t = torch.arange(seq_len, device=device, dtype=inv_freq.dtype)
            freqs = torch.outer(t, inv_freq)
            self._cos_cached = freqs.cos()[None, :, None, :]
            self._sin_cached = freqs.sin()[None, :, None, :]
            self._seq_len_cached = seq_len
        return self._cos_cached.to(dtype=dtype), self._sin_cached.to(dtype=dtype)


def apply_rotary_emb(x: Tensor, cos: Tensor, sin: Tensor, rope_dims: int = 0) -> Tensor:
    if rope_dims > 0 and rope_dims < x.size(-1):
        x_rope, x_passthrough = x[..., :rope_dims], x[..., rope_dims:]
        half = rope_dims // 2
        x1, x2 = x_rope[..., :half], x_rope[..., half:]
        rotated = torch.cat((x1 * cos + x2 * sin, x1 * (-sin) + x2 * cos), dim=-1)
        return torch.cat((rotated, x_passthrough), dim=-1)
    half = x.size(-1) // 2
    x1, x2 = x[..., :half], x[..., half:]
    return torch.cat((x1 * cos + x2 * sin, x1 * (-sin) + x2 * cos), dim=-1)


def _flash_or_sdpa_attention(
    q: Tensor,
    k: Tensor,
    v: Tensor,
    *,
    use_flash_attn: bool,
) -> Tensor:
    if use_flash_attn and flash_attn_3_func is not None and q.is_cuda:
        return flash_attn_3_func(q, k, v, causal=True)
    q_sdpa = q.transpose(1, 2)
    k_sdpa = k.transpose(1, 2)
    v_sdpa = v.transpose(1, 2)
    y = F.scaled_dot_product_attention(
        q_sdpa,
        k_sdpa,
        v_sdpa,
        is_causal=True,
        enable_gqa=(q_sdpa.size(1) != k_sdpa.size(1)),
    )
    return y.transpose(1, 2)


class CausalSelfAttention(nn.Module):
    def __init__(
        self,
        dim: int,
        num_heads: int,
        num_kv_heads: int,
        rope_base: float,
        qk_gain_init: float,
        *,
        rope_dims: int,
        use_xsa: bool,
        use_flash_attn: bool,
        glu_values: bool = False,
    ):
        super().__init__()
        self.glu_values = glu_values
        if dim % num_heads != 0:
            raise ValueError("model_dim must be divisible by num_heads")
        if num_heads % num_kv_heads != 0:
            raise ValueError("num_heads must be divisible by num_kv_heads")
        self.num_heads = num_heads
        self.num_kv_heads = num_kv_heads
        self.head_dim = dim // num_heads
        self.use_xsa = use_xsa
        self.use_flash_attn = use_flash_attn
        self.c_q = CastedLinear(dim, dim, bias=False)
        self.c_k = CastedLinear(dim, num_kv_heads * self.head_dim, bias=False)
        self.c_v = CastedLinear(dim, num_kv_heads * self.head_dim, bias=False)
        self.proj = CastedLinear(dim, dim, bias=False)
        self.proj._zero_init = True
        self.q_gain = nn.Parameter(torch.full((num_heads,), qk_gain_init, dtype=torch.float32))
        self.rope_dims = rope_dims
        self.rotary = Rotary(self.head_dim, base=rope_base, train_seq_len=1024, rope_dims=rope_dims)

    def _xsa_efficient(self, y: Tensor, v: Tensor) -> Tensor:
        bsz, seqlen, num_heads, head_dim = y.shape
        num_kv_heads = v.size(-2)
        group = num_heads // num_kv_heads
        y_grouped = y.reshape(bsz, seqlen, num_kv_heads, group, head_dim)
        v_norm = F.normalize(v, dim=-1).unsqueeze(-2)
        proj = (y_grouped * v_norm).sum(dim=-1, keepdim=True) * v_norm
        return (y_grouped - proj).reshape(bsz, seqlen, num_heads, head_dim)

    def forward(self, x: Tensor, v_embed: Tensor | None = None, q_delta: Tensor | None = None, v_delta: Tensor | None = None) -> Tensor:
        bsz, seqlen, dim = x.shape
        q = self.c_q(x)
        if q_delta is not None:
            q = q + q_delta
        q = q.reshape(bsz, seqlen, self.num_heads, self.head_dim)
        k = self.c_k(x).reshape(bsz, seqlen, self.num_kv_heads, self.head_dim)
        v = self.c_v(x)
        if v_delta is not None:
            v = v + v_delta
        if v_embed is not None:
            v = v + v_embed
        v = v.reshape(bsz, seqlen, self.num_kv_heads, self.head_dim)
        if self.glu_values:
            v = v * v.sigmoid()
        q = F.rms_norm(q, (q.size(-1),))
        k = F.rms_norm(k, (k.size(-1),))
        cos, sin = self.rotary(seqlen, x.device, q.dtype)
        q = apply_rotary_emb(q, cos, sin, self.rope_dims)
        k = apply_rotary_emb(k, cos, sin, self.rope_dims)
        q = q * self.q_gain.to(dtype=q.dtype)[None, None, :, None]
        y = _flash_or_sdpa_attention(q, k, v, use_flash_attn=self.use_flash_attn)
        if self.use_xsa:
            y = self._xsa_efficient(y, v)
        return self.proj(y.reshape(bsz, seqlen, dim))


class SmearGate(nn.Module):
    def __init__(self, dim: int):
        super().__init__()
        self.gate = nn.Parameter(torch.zeros(dim, dtype=torch.float32))

    def forward(self, x: Tensor) -> Tensor:
        gate = torch.sigmoid(self.gate.to(dtype=x.dtype))[None, None, :]
        x_prev = torch.cat([torch.zeros_like(x[:, :1]), x[:, :-1]], dim=1)
        return (1.0 - gate) * x + gate * x_prev


class BigramHashEmbedding(nn.Module):
    def __init__(self, bigram_vocab_size: int, bigram_dim: int, model_dim: int):
        super().__init__()
        self.bigram_vocab_size = bigram_vocab_size
        self.embed = nn.Embedding(bigram_vocab_size, bigram_dim)
        nn.init.zeros_(self.embed.weight)
        self.proj = CastedLinear(bigram_dim, model_dim, bias=False) if bigram_dim != model_dim else None
        if self.proj is not None:
            nn.init.zeros_(self.proj.weight)
        self.scale = nn.Parameter(torch.tensor(0.05, dtype=torch.float32))

    def _hash(self, tokens: Tensor) -> Tensor:
        token_int = tokens.to(torch.int32)
        modulo = self.bigram_vocab_size - 1
        out = torch.empty_like(token_int)
        out[..., 0] = modulo
        out[..., 1:] = torch.bitwise_xor(36313 * token_int[..., 1:], 27191 * token_int[..., :-1]) % modulo
        return out.long()

    def forward(self, token_ids: Tensor) -> Tensor:
        hidden = self.embed(self._hash(token_ids))
        if self.proj is not None:
            hidden = self.proj(hidden)
        return hidden * self.scale.to(dtype=hidden.dtype)


class ValueEmbedding(nn.Module):
    def __init__(self, vocab_size: int, ve_dim: int, kv_dim: int):
        super().__init__()
        self.embed = nn.Embedding(vocab_size, ve_dim)
        nn.init.normal_(self.embed.weight, std=0.01)
        self.proj = CastedLinear(ve_dim, kv_dim, bias=False) if ve_dim != kv_dim else None
        if self.proj is not None:
            nn.init.zeros_(self.proj.weight)
        self.scale = nn.Parameter(torch.tensor(0.1, dtype=torch.float32))

    def forward(self, token_ids: Tensor) -> Tensor:
        hidden = self.embed(token_ids)
        if self.proj is not None:
            hidden = self.proj(hidden)
        return hidden * self.scale.to(dtype=hidden.dtype)


class MLP(nn.Module):
    def __init__(self, dim: int, mlp_mult: float, activation_mode: str, leaky_relu_slope: float = 0.5):
        super().__init__()
        hidden_dim = int(mlp_mult * dim)
        self.activation_mode = activation_mode
        self.leaky_relu_slope = leaky_relu_slope
        self.fc = CastedLinear(dim, hidden_dim, bias=False)
        self.proj = CastedLinear(hidden_dim, dim, bias=False)
        self.proj._zero_init = True

    def forward(self, x: Tensor) -> Tensor:
        hidden = self.fc(x)
        if self.activation_mode == "leaky_relu2":
            hidden = F.leaky_relu(hidden, negative_slope=self.leaky_relu_slope)
        else:
            hidden = torch.relu(hidden)
        return self.proj(hidden.square())


class TransformerBlock(nn.Module):
    def __init__(self, config: ModelConfig, layer_idx: int, *, use_xsa: bool):
        super().__init__()
        self.attn_norm = RMSNorm()
        self.mlp_norm = RMSNorm()
        self.attn = CausalSelfAttention(
            config.model_dim,
            config.num_heads,
            config.num_kv_heads,
            config.rope_base,
            config.qk_gain_init,
            rope_dims=config.rope_dims,
            use_xsa=use_xsa,
            use_flash_attn=config.use_flash_attn,
            glu_values=config.glu_values,
        )
        self.mlp = MLP(config.model_dim, config.mlp_mult, config.activation_mode, config.leaky_relu_slope)
        self.attn_scale = nn.Parameter(torch.ones(config.model_dim, dtype=torch.float32))
        self.mlp_scale = nn.Parameter(torch.ones(config.model_dim, dtype=torch.float32))
        self.resid_mix = nn.Parameter(torch.stack((torch.ones(config.model_dim), torch.zeros(config.model_dim))).float())
        self.ln_scale_factor = 1.0 / math.sqrt(layer_idx + 1) if config.ln_scale else 1.0

    def forward(self, x: Tensor, x0: Tensor, v_embed: Tensor | None = None, q_delta: Tensor | None = None, v_delta: Tensor | None = None) -> Tensor:
        mix = self.resid_mix.to(dtype=x.dtype)
        x_in = mix[0][None, None, :] * x + mix[1][None, None, :] * x0
        attn_out = self.attn(self.attn_norm(x_in) * self.ln_scale_factor, v_embed=v_embed, q_delta=q_delta, v_delta=v_delta)
        x_out = x_in + self.attn_scale.to(dtype=x.dtype)[None, None, :] * attn_out
        x_out = x_out + self.mlp_scale.to(dtype=x.dtype)[None, None, :] * self.mlp(
            self.mlp_norm(x_out) * self.ln_scale_factor
        )
        return x_out


class LocalMixerBlock(nn.Module):
    def __init__(self, config: ModelConfig, layer_idx: int):
        super().__init__()
        self.kernel_size = config.local_kernel_size
        self.mix_norm = RMSNorm()
        self.mlp_norm = RMSNorm()
        self.mix_proj = CastedLinear(config.model_dim, config.model_dim, bias=False)
        self.mix_proj._zero_init = True
        self.mlp = MLP(config.model_dim, config.mlp_mult, config.activation_mode, config.leaky_relu_slope)
        self.mix_scale = nn.Parameter(torch.ones(config.model_dim, dtype=torch.float32))
        self.mlp_scale = nn.Parameter(torch.ones(config.model_dim, dtype=torch.float32))
        self.resid_mix = nn.Parameter(torch.stack((torch.ones(config.model_dim), torch.zeros(config.model_dim))).float())
        self.dw_weight = nn.Parameter(torch.zeros(config.model_dim, 1, self.kernel_size, dtype=torch.float32))
        self.ln_scale_factor = 1.0 / math.sqrt(layer_idx + 1) if config.ln_scale else 1.0
        with torch.no_grad():
            self.dw_weight[:, 0, -1] = 1.0

    def forward(self, x: Tensor, x0: Tensor) -> Tensor:
        mix = self.resid_mix.to(dtype=x.dtype)
        x_in = mix[0][None, None, :] * x + mix[1][None, None, :] * x0
        local = self.mix_norm(x_in) * self.ln_scale_factor
        local_t = local.transpose(1, 2)
        local_t = F.pad(local_t, (self.kernel_size - 1, 0))
        local_t = F.conv1d(local_t, self.dw_weight.to(dtype=local.dtype), groups=local.size(-1))
        local = self.mix_proj(local_t.transpose(1, 2))
        x_out = x_in + self.mix_scale.to(dtype=x.dtype)[None, None, :] * local
        x_out = x_out + self.mlp_scale.to(dtype=x.dtype)[None, None, :] * self.mlp(
            self.mlp_norm(x_out) * self.ln_scale_factor
        )
        return x_out


class ParameterGolfModel(nn.Module):
    def __init__(self, model_config: ModelConfig, vocab_size: int):
        super().__init__()
        self.config = copy.deepcopy(model_config)
        self.vocab_size = vocab_size
        self.tie_embeddings = model_config.tie_embeddings
        self.logit_softcap = model_config.logit_softcap
        self.tok_emb = nn.Embedding(vocab_size, model_config.model_dim)
        self.bigram = (
            BigramHashEmbedding(model_config.bigram_vocab_size, model_config.bigram_dim, model_config.model_dim)
            if model_config.bigram_vocab_size > 0
            else None
        )
        self.smear = SmearGate(model_config.model_dim)
        self.lower_replace_layers = model_config.lower_replace_layers
        self.use_unet_skips = model_config.use_unet_skips
        if self.lower_replace_layers > 0:
            self.lower_shared_blocks = nn.ModuleList(
                [LocalMixerBlock(model_config, layer_idx=i) for i in range(model_config.local_shared_blocks)]
            )
            upper_layers = model_config.num_layers - self.lower_replace_layers
            self.upper_blocks = nn.ModuleList(
                [
                    TransformerBlock(
                        model_config,
                        layer_idx=self.lower_replace_layers + i,
                        use_xsa=(self.lower_replace_layers + i) >= model_config.num_layers - model_config.xsa_last_n,
                    )
                    for i in range(upper_layers)
                ]
            )
            self.num_encoder_layers = 0
            self.num_decoder_layers = 0
            self.num_skip_weights = 0
            self.register_buffer("skip_weights", torch.zeros(0, model_config.model_dim, dtype=torch.float32))
        else:
            self.lower_shared_blocks = nn.ModuleList()
            self.upper_blocks = nn.ModuleList(
                [
                    TransformerBlock(
                        model_config,
                        layer_idx=i,
                        use_xsa=i >= model_config.num_layers - model_config.xsa_last_n,
                    )
                    for i in range(model_config.num_layers)
                ]
            )
            self.num_encoder_layers = model_config.num_layers // 2
            self.num_decoder_layers = model_config.num_layers - self.num_encoder_layers
            self.num_skip_weights = min(self.num_encoder_layers, self.num_decoder_layers) if self.use_unet_skips else 0
            self.skip_weights = nn.Parameter(torch.ones(self.num_skip_weights, model_config.model_dim, dtype=torch.float32))
        kv_dim = model_config.num_kv_heads * (model_config.model_dim // model_config.num_heads)
        raw_ve_layers = tuple(layer for layer in model_config.ve_layers if layer >= self.lower_replace_layers)
        self.ve_layer_indices = raw_ve_layers if model_config.ve_enabled else tuple()
        if self.ve_layer_indices:
            self.ve_shared = ValueEmbedding(vocab_size, model_config.ve_dim, kv_dim)
            self.ve_layer_scales = nn.ParameterList(
                [nn.Parameter(torch.ones(1, dtype=torch.float32)) for _ in self.ve_layer_indices]
            )
        else:
            self.ve_shared = None
            self.ve_layer_scales = nn.ParameterList()
        self.final_norm = RMSNorm()
        self.lm_head = None if self.tie_embeddings else CastedLinear(model_config.model_dim, vocab_size, bias=False)
        if self.lm_head is not None:
            self.lm_head._zero_init = True
        self._init_weights()

    def _init_weights(self) -> None:
        if self.tie_embeddings:
            nn.init.normal_(self.tok_emb.weight, mean=0.0, std=self.config.tied_embed_init_std)
        num_layers = max(len(self.upper_blocks), 1)
        for name, module in self.named_modules():
            if isinstance(module, nn.Linear):
                if getattr(module, "_zero_init", False):
                    nn.init.zeros_(module.weight)
                elif module.weight.ndim == 2 and module.weight.shape[0] >= 64 and module.weight.shape[1] >= 64:
                    nn.init.orthogonal_(module.weight, gain=1.0)
                    if ".proj" in name:
                        with torch.no_grad():
                            module.weight.mul_(1.0 / math.sqrt(2 * num_layers))

    @classmethod
    def from_exported_state(
        cls,
        state_dict: dict[str, Tensor],
        model_config: ModelConfig,
        vocab_size: int,
        device: torch.device,
    ) -> "ParameterGolfModel":
        model = cls(model_config, vocab_size).to(device).bfloat16()
        for module in model.modules():
            if isinstance(module, CastedLinear):
                module.float()
        restore_low_dim_params_to_fp32(model)
        model.load_state_dict(state_dict, strict=True)
        return model

    def artifact_state_dict(self) -> dict[str, Tensor]:
        return self.state_dict()

    def parameter_breakdown(self) -> dict[str, int]:
        breakdown: dict[str, int] = defaultdict(int)
        for name, param in self.named_parameters():
            subsystem, _ = classify_tensor(name)
            breakdown[subsystem] += int(param.numel())
        return dict(sorted(breakdown.items()))

    def _get_ve(self, logical_layer_idx: int, input_ids: Tensor, cache: dict[str, Tensor]) -> Tensor | None:
        if self.ve_shared is None or logical_layer_idx not in self.ve_layer_indices:
            return None
        if "ve" not in cache:
            cache["ve"] = self.ve_shared(input_ids)
        ve_idx = self.ve_layer_indices.index(logical_layer_idx)
        return cache["ve"] * self.ve_layer_scales[ve_idx].to(dtype=cache["ve"].dtype)

    def _stem(self, input_ids: Tensor) -> Tensor:
        x = self.tok_emb(input_ids)
        if self.bigram is not None:
            x = x + self.bigram(input_ids)
        x = F.rms_norm(x, (x.size(-1),))
        return self.smear(x)

    def _get_lora_deltas(self, lora, block_idx: int, x: Tensor) -> tuple[Tensor | None, Tensor | None]:
        if lora is None:
            return None, None
        q_lora = lora.q_loras[block_idx]
        v_lora = lora.v_loras[block_idx]
        qd = q_lora(x) if q_lora is not None else None
        vd = v_lora(x) if v_lora is not None else None
        return qd, vd

    def _run_control_stack(self, x: Tensor, input_ids: Tensor, lora=None) -> Tensor:
        x0 = x
        skips: list[Tensor] = []
        cache: dict[str, Tensor] = {}
        for idx in range(self.num_encoder_layers):
            ve = self._get_ve(idx, input_ids, cache)
            qd, vd = self._get_lora_deltas(lora, idx, x)
            x = self.upper_blocks[idx](x, x0, v_embed=ve, q_delta=qd, v_delta=vd)
            if self.use_unet_skips:
                skips.append(x)
        for idx in range(self.num_decoder_layers):
            logical_idx = self.num_encoder_layers + idx
            if self.use_unet_skips and skips:
                x = x + self.skip_weights[idx].to(dtype=x.dtype)[None, None, :] * skips.pop()
            ve = self._get_ve(logical_idx, input_ids, cache)
            qd, vd = self._get_lora_deltas(lora, logical_idx, x)
            x = self.upper_blocks[logical_idx](x, x0, v_embed=ve, q_delta=qd, v_delta=vd)
        return x

    def _run_moonshot_stack(self, x: Tensor, input_ids: Tensor, lora=None) -> Tensor:
        x0 = x
        cache: dict[str, Tensor] = {}
        for idx in range(self.lower_replace_layers):
            block = self.lower_shared_blocks[idx % len(self.lower_shared_blocks)]
            x = block(x, x0)
        for idx, block in enumerate(self.upper_blocks):
            logical_idx = self.lower_replace_layers + idx
            ve = self._get_ve(logical_idx, input_ids, cache)
            qd, vd = self._get_lora_deltas(lora, logical_idx, x)
            x = block(x, x0, v_embed=ve, q_delta=qd, v_delta=vd)
        return x

    def _hidden(self, input_ids: Tensor, lora=None) -> Tensor:
        x = self._stem(input_ids)
        if self.lower_replace_layers > 0:
            x = self._run_moonshot_stack(x, input_ids, lora=lora)
        else:
            x = self._run_control_stack(x, input_ids, lora=lora)
        return self.final_norm(x)

    def forward_logits(self, input_ids: Tensor, lora=None, temperature: float = 1.0) -> Tensor:
        hidden = self._hidden(input_ids, lora=lora)
        bsz, sl, dim = hidden.shape
        hidden_flat = hidden.reshape(-1, dim)
        if self.tie_embeddings:
            logits_proj = F.linear(hidden_flat, self.tok_emb.weight)
        else:
            if self.lm_head is None:
                raise RuntimeError("lm_head is required when tie_embeddings=False")
            logits_proj = self.lm_head(hidden_flat)
        logits_proj = logits_proj.view(bsz, sl, self.vocab_size)
        if lora is not None:
            logits_proj = logits_proj + lora.lm_head_lora(hidden)
        if temperature != 1.0:
            logits_proj = logits_proj / temperature
        if self.logit_softcap > 0:
            logits = self.logit_softcap * torch.tanh(logits_proj / self.logit_softcap)
        else:
            logits = logits_proj
        return logits

    def forward(self, input_ids: Tensor, target_ids: Tensor, lora=None, temperature: float = 1.0) -> Tensor:
        # Fast path: fused linear + CE when Liger is available and no LoRA/softcap interference
        if (
            _liger_available
            and lora is None
            and self.logit_softcap <= 0
            and temperature == 1.0
            and self.tie_embeddings
        ):
            hidden = self._hidden(input_ids)
            hidden_flat = hidden.reshape(-1, hidden.size(-1))
            targets = target_ids.reshape(-1)
            return LigerFusedLinearCrossEntropyFunction.apply(
                hidden_flat, self.tok_emb.weight, targets, None, 0, 0, 0.0, True, "mean",
            )
        logits = self.forward_logits(input_ids, lora=lora, temperature=temperature).reshape(-1, self.vocab_size)
        targets = target_ids.reshape(-1)
        if lora is not None:
            bsz, sl = input_ids.shape
            return F.cross_entropy(logits.float(), targets, reduction="none").reshape(bsz, sl)
        return F.cross_entropy(logits.float(), targets, reduction="mean")


# ---------------------------------------------------------------------------
# TEST-TIME TRAINING (LoRA)
# ---------------------------------------------------------------------------

BOS_ID = 1


class BatchedLinearLoRA(nn.Module):
    """LoRA adapter with independent weights per batch element."""

    def __init__(self, bsz: int, in_features: int, out_features: int, rank: int):
        super().__init__()
        self.in_features = in_features
        self.A = nn.Parameter(torch.empty(bsz, rank, in_features))
        self.B = nn.Parameter(torch.zeros(bsz, out_features, rank))
        self.reset()

    def forward(self, x: Tensor) -> Tensor:
        return (x @ self.A.transpose(1, 2)) @ self.B.transpose(1, 2)

    def reset(self) -> None:
        bound = 1.0 / math.sqrt(self.in_features)
        with torch.no_grad():
            self.A.uniform_(-bound, bound)
            self.B.zero_()


class BatchedTTTLoRA(nn.Module):
    """All LoRA adapters for one batch: LM head + Q/V per transformer block."""

    def __init__(self, bsz: int, model: ParameterGolfModel, rank: int):
        super().__init__()
        dim = model.config.model_dim
        vocab = model.vocab_size
        self.lm_head_lora = BatchedLinearLoRA(bsz, dim, vocab, rank)
        self.q_loras = nn.ModuleList()
        self.v_loras = nn.ModuleList()
        num_blocks = model.config.num_layers
        for layer_idx in range(num_blocks):
            if layer_idx < model.lower_replace_layers:
                self.q_loras.append(None)
                self.v_loras.append(None)
            else:
                upper_idx = layer_idx - model.lower_replace_layers
                block = model.upper_blocks[upper_idx]
                self.q_loras.append(BatchedLinearLoRA(bsz, dim, block.attn.c_q.weight.shape[0], rank))
                self.v_loras.append(BatchedLinearLoRA(bsz, dim, block.attn.c_v.weight.shape[0], rank))

    def reset(self) -> None:
        for m in self.modules():
            if isinstance(m, BatchedLinearLoRA):
                m.reset()


def _reset_ttt_optimizer(opt: torch.optim.Optimizer) -> None:
    for group in opt.param_groups:
        for p in group["params"]:
            s = opt.state.get(p)
            if not s:
                continue
            for key, value in s.items():
                if torch.is_tensor(value):
                    value.zero_()
                elif isinstance(value, (int, float)):
                    s[key] = type(value)()


def _build_ttt_param_groups(
    lora: BatchedTTTLoRA,
    *,
    base_lr: float,
    grouped_lr: bool,
    head_lr_scale: float,
    q_lr_scale: float,
    v_lr_scale: float,
) -> list[dict[str, Any]]:
    if not grouped_lr:
        return [{"params": list(lora.parameters()), "lr": base_lr, "base_lr": base_lr, "group_name": "all"}]

    grouped: dict[str, dict[str, Any]] = {}
    for name, param in lora.named_parameters():
        if not param.requires_grad:
            continue
        if name.startswith("lm_head_lora"):
            group_name, lr_scale = "lm_head", head_lr_scale
        elif ".q_loras." in name:
            group_name, lr_scale = "q_lora", q_lr_scale
        elif ".v_loras." in name:
            group_name, lr_scale = "v_lora", v_lr_scale
        else:
            group_name, lr_scale = "other", 1.0
        if group_name not in grouped:
            grouped[group_name] = {
                "params": [],
                "lr": base_lr * lr_scale,
                "base_lr": base_lr * lr_scale,
                "group_name": group_name,
            }
        grouped[group_name]["params"].append(param)
    return [group for _, group in sorted(grouped.items()) if group["params"]]


def _build_ttt_optimizer(
    lora: BatchedTTTLoRA,
    optimizer_name: str,
    lr: float,
    betas: tuple[float, float],
    weight_decay: float,
    *,
    grouped_lr: bool,
    head_lr_scale: float,
    q_lr_scale: float,
    v_lr_scale: float,
    sgd_momentum: float,
) -> torch.optim.Optimizer:
    param_groups = _build_ttt_param_groups(
        lora,
        base_lr=lr,
        grouped_lr=grouped_lr,
        head_lr_scale=head_lr_scale,
        q_lr_scale=q_lr_scale,
        v_lr_scale=v_lr_scale,
    )
    if optimizer_name == "adamw":
        return torch.optim.AdamW(param_groups, lr=lr, betas=betas, eps=1e-10, weight_decay=weight_decay)
    return torch.optim.SGD(param_groups, lr=lr, momentum=sgd_momentum, weight_decay=weight_decay)


def _ttt_schedule_scale(
    schedule: str,
    chunk_idx: int,
    max_chunks: int,
    cosine_min_lr_scale: float,
) -> float:
    if schedule == "constant" or max_chunks <= 1:
        return 1.0
    progress = chunk_idx / max(max_chunks - 1, 1)
    cosine = 0.5 * (1.0 + math.cos(math.pi * progress))
    return cosine_min_lr_scale + (1.0 - cosine_min_lr_scale) * cosine


def _apply_ttt_lr_schedule(opt: torch.optim.Optimizer, schedule_scale: float) -> None:
    for group in opt.param_groups:
        base_lr = float(group.get("base_lr", group["lr"]))
        group["lr"] = base_lr * schedule_scale


def _find_docs(all_tokens: Tensor) -> list[tuple[int, int]]:
    """Return (start_offset, length) for each document, identified by BOS boundaries."""
    bos_positions = (all_tokens == BOS_ID).nonzero(as_tuple=True)[0].numpy()
    docs: list[tuple[int, int]] = []
    for i in range(len(bos_positions)):
        start = int(bos_positions[i])
        end = int(bos_positions[i + 1]) if i + 1 < len(bos_positions) else all_tokens.numel()
        if i + 1 < len(bos_positions):
            end += 1
        if end - start >= 2:
            docs.append((start, end - start))
    return docs


def _compute_chunk_window(
    ci: int, pred_len: int, num_chunks: int, chunk_size: int, eval_seq_len: int
) -> tuple[int, int, int, int]:
    """Return (win_start, win_len, chunk_offset, chunk_len) for chunk ci."""
    chunk_start = ci * chunk_size
    chunk_end = pred_len if ci == num_chunks - 1 else (ci + 1) * chunk_size
    win_start = max(0, chunk_end - eval_seq_len)
    win_len = chunk_end - win_start
    chunk_offset = chunk_start - win_start
    chunk_len = chunk_end - chunk_start
    return win_start, win_len, chunk_offset, chunk_len


def _accumulate_bpb(
    ptl: Tensor,
    x: Tensor,
    y: Tensor,
    batch_i: int,
    chunk_offset: int,
    chunk_len: int,
    luts: tuple[Tensor, Tensor, Tensor],
    loss_sum: Tensor,
    byte_sum: Tensor,
    token_count: Tensor,
) -> None:
    """Add one doc-chunk's contribution to the running BPB accumulators."""
    lbl = ptl[batch_i, chunk_offset : chunk_offset + chunk_len].to(torch.float64)
    prev = x[batch_i, chunk_offset : chunk_offset + chunk_len]
    tgt = y[batch_i, chunk_offset : chunk_offset + chunk_len]
    tok_bytes = _score_token_bytes(prev, tgt, luts).to(torch.float64)
    loss_sum += lbl.sum()
    byte_sum += tok_bytes.sum()
    token_count += chunk_len


def eval_ttt(
    config: ExperimentConfig,
    model: nn.Module,
    rank: int,
    world_size: int,
    device: torch.device,
    val_tokens: Tensor,
    luts: tuple[Tensor, Tensor, Tensor],
    precomputed_docs: list[tuple[int, int]] | None = None,
) -> EvalResult:
    """Score-first LoRA test-time training evaluation."""
    if not config.eval.ttt_enforce_score_first:
        raise ValueError("TTT must run with score-first enforcement enabled")
    if config.eval.ttt_allow_hindsight_selection:
        raise ValueError("Hindsight selection is disabled in the strict-legal TTT path")
    docs = precomputed_docs if precomputed_docs is not None else _find_docs(val_tokens)
    rank_docs = docs[(len(docs) * rank) // world_size : (len(docs) * (rank + 1)) // world_size]
    chunk_size = config.eval.ttt_chunk_size
    eval_seq_len = config.eval.eval_seq_len or config.train.train_seq_len
    if chunk_size > eval_seq_len:
        raise ValueError(
            "TTT_CHUNK_SIZE must be <= EVAL_SEQ_LEN in the current TTT implementation; "
            "the 32K-chunk path needs sliding-within-chunk scoring before it is valid"
        )
    batch_size = config.eval.ttt_batch_size
    lora_rank = config.eval.ttt_lora_rank

    rank_docs.sort(key=lambda d: (d[1] - 2) // chunk_size)

    base_model = model
    while hasattr(base_model, "_orig_mod"):
        base_model = base_model._orig_mod

    base_model.eval()
    for p in base_model.parameters():
        p.requires_grad_(False)

    lora = BatchedTTTLoRA(batch_size, base_model, lora_rank).to(device)
    opt = _build_ttt_optimizer(
        lora,
        config.eval.ttt_optimizer,
        config.eval.ttt_lora_lr,
        (config.train.beta1, config.train.beta2),
        config.eval.ttt_weight_decay,
        grouped_lr=config.eval.ttt_grouped_lr,
        head_lr_scale=config.eval.ttt_head_lr_scale,
        q_lr_scale=config.eval.ttt_q_lr_scale,
        v_lr_scale=config.eval.ttt_v_lr_scale,
        sgd_momentum=config.eval.ttt_sgd_momentum,
    )

    loss_sum = torch.zeros((), device=device, dtype=torch.float64)
    byte_sum = torch.zeros((), device=device, dtype=torch.float64)
    token_count = torch.zeros((), device=device, dtype=torch.float64)
    start = time.perf_counter()

    for bi in range(0, len(rank_docs), batch_size):
        batch = rank_docs[bi : bi + batch_size]
        bsz = len(batch)

        if bsz == batch_size:
            cur_lora, cur_opt = lora, opt
            cur_lora.reset()
            _reset_ttt_optimizer(cur_opt)
        else:
            cur_lora = BatchedTTTLoRA(bsz, base_model, lora_rank).to(device)
            cur_opt = _build_ttt_optimizer(
                cur_lora,
                config.eval.ttt_optimizer,
                config.eval.ttt_lora_lr,
                (config.train.beta1, config.train.beta2),
                config.eval.ttt_weight_decay,
                grouped_lr=config.eval.ttt_grouped_lr,
                head_lr_scale=config.eval.ttt_head_lr_scale,
                q_lr_scale=config.eval.ttt_q_lr_scale,
                v_lr_scale=config.eval.ttt_v_lr_scale,
                sgd_momentum=config.eval.ttt_sgd_momentum,
            )

        polyak_decay = config.eval.ttt_polyak_decay
        polyak_state: list[Tensor] | None = None
        if polyak_decay > 0:
            polyak_state = [p.data.clone() for p in cur_lora.parameters()]

        pred_lens = [doc_len - 1 for _, doc_len in batch]
        num_chunks = [(pl + chunk_size - 1) // chunk_size for pl in pred_lens]
        max_nc = max(num_chunks)

        for ci in range(max_nc):
            chunk_stats = _compute_chunk_window(ci, (ci + 1) * chunk_size, ci + 1, chunk_size, eval_seq_len)
            context_size = chunk_stats[1]

            active = [ci < nc for nc in num_chunks]
            needs_train = any(ci < nc - 1 for nc in num_chunks)

            x = torch.zeros(bsz, context_size, dtype=torch.int64, device=device)
            y = torch.zeros(bsz, context_size, dtype=torch.int64, device=device)
            doc_info: list[tuple[int, int]] = []
            for b in range(bsz):
                if not active[b]:
                    doc_info.append((0, 0))
                    continue
                ds, dl = batch[b]
                ws, wl, co, cl = _compute_chunk_window(ci, pred_lens[b], num_chunks[b], chunk_size, eval_seq_len)
                chunk = val_tokens[ds + ws : ds + ws + wl + 1]
                toks = chunk.to(dtype=torch.int64, device=device)
                x[b, :wl] = toks[:-1]
                y[b, :wl] = toks[1:]
                doc_info.append((co, cl))

            # Swap in Polyak-averaged weights for scoring (if available)
            _polyak_saved: list[Tensor] | None = None
            if polyak_state is not None and ci > 0:
                _polyak_saved = [p.data.clone() for p in cur_lora.parameters()]
                with torch.no_grad():
                    for p, avg in zip(cur_lora.parameters(), polyak_state):
                        p.data.copy_(avg)

            if needs_train:
                with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                    ptl = base_model(x, y, lora=cur_lora, temperature=config.eval.ttt_temperature)
            else:
                with torch.no_grad(), torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                    ptl = base_model(x, y, lora=cur_lora, temperature=config.eval.ttt_temperature)

            with torch.no_grad():
                for b in range(bsz):
                    if not active[b]:
                        continue
                    co, cl = doc_info[b]
                    _accumulate_bpb(ptl, x, y, b, co, cl, luts, loss_sum, byte_sum, token_count)

            # Restore training weights before gradient step
            if _polyak_saved is not None:
                with torch.no_grad():
                    for p, s in zip(cur_lora.parameters(), _polyak_saved):
                        p.data.copy_(s)

            if needs_train:
                schedule_scale = _ttt_schedule_scale(
                    config.eval.ttt_lr_schedule,
                    ci,
                    max_nc,
                    config.eval.ttt_cosine_min_lr_scale,
                )
                _apply_ttt_lr_schedule(cur_opt, schedule_scale)
                mask = torch.tensor([float(ci < num_chunks[b] - 1) for b in range(bsz)], device=device)
                for epoch_idx in range(config.eval.ttt_epochs):
                    ptl_train = ptl
                    if epoch_idx > 0:
                        with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                            ptl_train = base_model(x, y, lora=cur_lora, temperature=config.eval.ttt_temperature)
                    per_doc = ptl_train[:, chunk_stats[2] : chunk_stats[2] + chunk_size].mean(dim=-1)
                    cur_opt.zero_grad()
                    (per_doc * mask).sum().backward()
                    if config.eval.ttt_grad_clip_norm > 0:
                        torch.nn.utils.clip_grad_norm_(cur_lora.parameters(), config.eval.ttt_grad_clip_norm)
                    cur_opt.step()
                # Update Polyak running average after all TTT epochs
                if polyak_state is not None:
                    with torch.no_grad():
                        for p, avg in zip(cur_lora.parameters(), polyak_state):
                            avg.mul_(polyak_decay).add_(p.data, alpha=1.0 - polyak_decay)

    for p in base_model.parameters():
        p.requires_grad_(True)

    if dist.is_available() and dist.is_initialized():
        dist.all_reduce(loss_sum, op=dist.ReduceOp.SUM)
        dist.all_reduce(byte_sum, op=dist.ReduceOp.SUM)
        dist.all_reduce(token_count, op=dist.ReduceOp.SUM)

    val_loss = float(loss_sum.item() / token_count.item())
    val_bpb = float((loss_sum.item() / math.log(2.0)) / byte_sum.item())
    return EvalResult(
        val_loss=val_loss,
        val_bpb=val_bpb,
        eval_ms=1000.0 * (time.perf_counter() - start),
        eval_seq_len=eval_seq_len,
    )


# ---------------------------------------------------------------------------
# N-GRAM EVAL CACHE (Vectorized)
# ---------------------------------------------------------------------------

_NGRAM_PRIMES = np.array([36313, 27191, 51647, 81929, 131071, 174763, 233017, 283721, 347237], dtype=np.uint64)


def _batch_hash_ctx(tokens_np: np.ndarray, positions: np.ndarray, n: int, bucket_mask: int) -> np.ndarray:
    """Vectorized context hash for all positions at once using XOR-of-products."""
    h = np.zeros(len(positions), dtype=np.uint64)
    for k in range(n - 1):
        idx = positions - (n - 1) + k
        idx = np.clip(idx, 0, len(tokens_np) - 1)
        h ^= tokens_np[idx].astype(np.uint64) * _NGRAM_PRIMES[k]
    return h & np.uint64(bucket_mask)


def _batch_hash_full(tokens_np: np.ndarray, positions: np.ndarray, targets: np.ndarray, n: int, bucket_mask: int) -> np.ndarray:
    """Vectorized context+target hash for all positions at once."""
    h = np.zeros(len(positions), dtype=np.uint64)
    for k in range(n - 1):
        idx = positions - (n - 1) + k
        idx = np.clip(idx, 0, len(tokens_np) - 1)
        h ^= tokens_np[idx].astype(np.uint64) * _NGRAM_PRIMES[k]
    h ^= targets.astype(np.uint64) * _NGRAM_PRIMES[min(n - 1, len(_NGRAM_PRIMES) - 1)]
    return h & np.uint64(bucket_mask)


class NgramEvalCache:
    """Backward-looking N-gram frequency cache for eval-time score improvement.

    Legal under competition rules: only uses already-scored tokens.
    Updates happen AFTER scoring each segment. All operations are vectorized.
    """

    def __init__(self, max_order: int = 7, min_order: int = 2, num_buckets: int = 4194304, min_count: int = 2):
        if num_buckets <= 0 or (num_buckets & (num_buckets - 1)) != 0:
            raise ValueError("num_buckets must be a positive power of two")
        self.max_order = max_order
        self.min_order = min_order
        self.num_buckets = num_buckets
        self.bucket_mask = num_buckets - 1  # power-of-2 masking
        self.min_count = min_count
        self.ctx_tables: list[np.ndarray] = [np.zeros(num_buckets, dtype=np.int32) for _ in range(max_order + 1)]
        self.full_tables: list[np.ndarray] = [np.zeros(num_buckets, dtype=np.int32) for _ in range(max_order + 1)]

    def batch_lookup(self, tokens_np: np.ndarray, positions: np.ndarray, targets: np.ndarray) -> tuple[np.ndarray, np.ndarray, np.ndarray]:
        """Vectorized multi-order backoff lookup for all positions at once.

        `positions` are target-token indices in the raw token stream, so `targets[i] == tokens_np[positions[i]]`.
        Returns (ngram_probs, matched_mask, matched_orders) arrays of shape (len(positions),).
        """
        n_pos = len(positions)
        ngram_p = np.zeros(n_pos, dtype=np.float64)
        matched = np.zeros(n_pos, dtype=bool)
        matched_orders = np.zeros(n_pos, dtype=np.int32)

        for n in range(self.max_order, self.min_order - 1, -1):
            eligible = (~matched) & (positions >= n - 1)
            if not eligible.any():
                continue
            elig_pos = positions[eligible]
            elig_tgt = targets[eligible]
            ctx_keys = _batch_hash_ctx(tokens_np, elig_pos, n, self.bucket_mask).astype(np.int64)
            ctx_counts = self.ctx_tables[n][ctx_keys]
            has_data = ctx_counts >= self.min_count
            if not has_data.any():
                continue
            full_keys = _batch_hash_full(tokens_np, elig_pos[has_data], elig_tgt[has_data], n, self.bucket_mask).astype(np.int64)
            full_counts = self.full_tables[n][full_keys]
            capped_full = np.minimum(full_counts, ctx_counts[has_data])
            probs = capped_full.astype(np.float64) / np.maximum(ctx_counts[has_data].astype(np.float64), 1.0)
            elig_indices = np.where(eligible)[0]
            data_indices = elig_indices[has_data]
            ngram_p[data_indices] = probs
            matched[data_indices] = True
            matched_orders[data_indices] = n

        return ngram_p, matched, matched_orders

    def update_batch(self, tokens_np: np.ndarray, start_pos: int, end_pos: int) -> None:
        """Vectorized cache update for target-token indices in [start_pos, end_pos)."""
        if end_pos <= start_pos:
            return
        positions = np.arange(start_pos, end_pos, dtype=np.int64)
        targets = tokens_np[positions].astype(np.int64)
        for n in range(self.min_order, self.max_order + 1):
            valid = positions >= n - 1
            if not valid.any():
                continue
            v_pos = positions[valid]
            v_tgt = targets[valid]
            ctx_keys = _batch_hash_ctx(tokens_np, v_pos, n, self.bucket_mask).astype(np.int64)
            full_keys = _batch_hash_full(tokens_np, v_pos, v_tgt, n, self.bucket_mask).astype(np.int64)
            self.ctx_tables[n] += np.bincount(ctx_keys, minlength=self.num_buckets).astype(np.int32)
            self.full_tables[n] += np.bincount(full_keys, minlength=self.num_buckets).astype(np.int32)


def _build_sliding_segments(total_tokens: int, seq_len: int, stride: int) -> list[tuple[int, int, int, int, int, int]]:
    """Build the exact scored token ranges used by sliding-window evaluation.

    Each tuple is:
        (window_start, valid_len, local_score_start, local_score_end, target_start, target_end)
    where target positions are end-exclusive raw-token indices.
    """
    if total_tokens <= 0:
        return []
    segments: list[tuple[int, int, int, int, int, int]] = []
    first_valid_len = min(seq_len, total_tokens)
    segments.append((0, first_valid_len, 0, first_valid_len, 1, first_valid_len + 1))

    next_target_start = first_valid_len + 1
    while next_target_start <= total_tokens:
        target_end = min(next_target_start + stride, total_tokens + 1)
        window_end = target_end - 1
        window_start = max(0, window_end - seq_len)
        valid_len = window_end - window_start
        local_score_start = next_target_start - window_start - 1
        local_score_end = target_end - window_start - 1
        segments.append((window_start, valid_len, local_score_start, local_score_end, next_target_start, target_end))
        next_target_start = target_end

    if segments[-1][5] != total_tokens + 1:
        raise ValueError(
            f"Sliding segments ended at {segments[-1][5]}, expected {total_tokens + 1}"
        )
    return segments


def _score_chunks_ngram(
    config: ExperimentConfig,
    model: nn.Module,
    rank: int,
    world_size: int,
    device: torch.device,
    val_tokens: Tensor,
    tokens_np: np.ndarray,
    luts: tuple[Tensor, Tensor, Tensor],
    cache: "NgramEvalCache",
    segments: list,
    chunk_ranges: list[tuple[int, int]],
    seg_index_ranges: list[tuple[int, int]],
    seq_len: int,
    update_cache: bool = True,
) -> list[tuple[float, float, int]]:
    """Score a list of chunks against the given cache. Returns per-chunk (loss, bytes, tokens).

    If update_cache=True, cache is updated after each chunk (pass 1 behavior).
    If update_cache=False, cache is NOT updated (pass 2 rescore behavior).
    """
    total_tokens = val_tokens.numel() - 1
    adaptive = config.eval.ngram_eval_adaptive
    alpha_min = config.eval.ngram_eval_alpha_min
    alpha_max = config.eval.ngram_eval_alpha_max
    entropy_center = config.eval.ngram_eval_entropy_center
    entropy_scale = config.eval.ngram_eval_entropy_scale
    order_mults = np.array(config.eval.ngram_eval_order_mults, dtype=np.float64) if config.eval.ngram_eval_order_mults else None

    chunk_results: list[tuple[float, float, int]] = []

    with torch.inference_mode():
        for ci, (chunk_start, chunk_end) in enumerate(chunk_ranges):
            seg_start_idx, seg_end_idx = seg_index_ranges[ci]
            chunk_segments = segments[seg_start_idx:seg_end_idx]
            rank_segments = chunk_segments[rank::world_size]

            chunk_loss = 0.0
            chunk_bytes = 0.0
            chunk_tokens = 0

            for batch_idx in range(0, len(rank_segments), config.eval.eval_batch_seqs):
                batch_segments = rank_segments[batch_idx: batch_idx + config.eval.eval_batch_seqs]
                batch_size = len(batch_segments)
                x_batch = torch.zeros(batch_size, seq_len, dtype=torch.int64, device=device)
                y_batch = torch.zeros(batch_size, seq_len, dtype=torch.int64, device=device)
                for row_idx, (window_start, valid_len, _, _, _, _) in enumerate(batch_segments):
                    end = min(window_start + seq_len, total_tokens)
                    chunk = val_tokens[window_start: end + 1].to(device=device, dtype=torch.int64)
                    x_batch[row_idx, :valid_len] = chunk[:-1]
                    y_batch[row_idx, :valid_len] = chunk[1:]

                with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                    logits = model.forward_logits(x_batch)

                for row_idx, (_, _, local_score_start, local_score_end, target_start, target_end) in enumerate(batch_segments):
                    seg_len = target_end - target_start
                    row_logits = logits[row_idx, local_score_start:local_score_end].float()
                    row_targets = y_batch[row_idx, local_score_start:local_score_end]

                    model_probs_full = torch.softmax(row_logits, dim=-1)
                    target_indices = row_targets.unsqueeze(-1)
                    seg_model_p = torch.gather(model_probs_full, 1, target_indices).squeeze(-1)
                    seg_model_p = seg_model_p.clamp(min=1e-10).cpu().numpy().astype(np.float64)

                    if adaptive:
                        log_probs_full = torch.log_softmax(row_logits, dim=-1)
                        seg_entropy = -(model_probs_full * log_probs_full).sum(dim=-1).cpu().numpy()

                    global_positions = np.arange(target_start, target_end, dtype=np.int64)
                    seg_targets_np = row_targets.cpu().numpy().astype(np.int64)
                    ngram_p, ng_matched, ng_orders = cache.batch_lookup(tokens_np, global_positions, seg_targets_np)

                    final_p = seg_model_p.copy()
                    if ng_matched.any():
                        if adaptive:
                            matched_ords = ng_orders[ng_matched].astype(np.float64)
                            centers = entropy_center - 0.25 * (matched_ords - cache.min_order)
                            sig = 1.0 / (1.0 + np.exp(-entropy_scale * (seg_entropy[ng_matched] - centers)))
                            alpha = alpha_min + (alpha_max - alpha_min) * sig
                        else:
                            alpha = (alpha_min + alpha_max) / 2.0
                        if order_mults is not None:
                            mult_indices = ng_orders[ng_matched] - cache.min_order
                            mult_indices = np.clip(mult_indices, 0, len(order_mults) - 1)
                            alpha = alpha * order_mults[mult_indices]
                        alpha = np.clip(alpha, 0.0, 0.95)
                        final_p[ng_matched] = (1.0 - alpha) * seg_model_p[ng_matched] + alpha * ngram_p[ng_matched]
                        final_p = np.maximum(final_p, 1e-10)

                    chunk_loss += float((-np.log(final_p)).sum())
                    scored_x = x_batch[row_idx, local_score_start:local_score_end].reshape(-1)
                    scored_y = y_batch[row_idx, local_score_start:local_score_end].reshape(-1)
                    tok_bytes = _score_token_bytes(scored_x, scored_y, luts)
                    chunk_bytes += float(tok_bytes.to(torch.float64).sum().item())
                    chunk_tokens += seg_len

            # Reduce per-chunk across ranks
            if dist.is_available() and dist.is_initialized():
                t_loss = torch.tensor(chunk_loss, device=device, dtype=torch.float64)
                t_bytes = torch.tensor(chunk_bytes, device=device, dtype=torch.float64)
                t_tokens = torch.tensor(float(chunk_tokens), device=device, dtype=torch.float64)
                dist.all_reduce(t_loss, op=dist.ReduceOp.SUM)
                dist.all_reduce(t_bytes, op=dist.ReduceOp.SUM)
                dist.all_reduce(t_tokens, op=dist.ReduceOp.SUM)
                chunk_loss = t_loss.item()
                chunk_bytes = t_bytes.item()
                chunk_tokens = int(t_tokens.item())

            chunk_results.append((chunk_loss, chunk_bytes, chunk_tokens))

            if update_cache:
                cache.update_batch(tokens_np, chunk_start, chunk_end)

    return chunk_results


def eval_ngram(
    config: ExperimentConfig,
    model: nn.Module,
    rank: int,
    world_size: int,
    device: torch.device,
    val_tokens: Tensor,
    luts: tuple[Tensor, Tensor, Tensor],
    *,
    eval_seq_len: int | None = None,
) -> EvalResult:
    """Two-pass N-gram eval. Pass 1: standard score-first eval building the cache.
    Pass 2: rescore early (cold-cache) chunks using the now-complete cache.
    All rescored tokens were already evaluated in Pass 1, so this is compliant
    with the backward-looking rule."""
    seq_len = eval_seq_len or config.eval.eval_seq_len or config.train.train_seq_len
    stride = config.eval.sliding_stride
    total_tokens = val_tokens.numel() - 1
    tokens_np = val_tokens.numpy().astype(np.int64)
    chunk_tokens = config.eval.ngram_eval_chunk_tokens
    two_pass = config.eval.ngram_two_pass_enabled
    rescore_n = config.eval.ngram_two_pass_rescore_chunks
    pass2_policy = config.eval.ngram_two_pass_policy
    pass2_min_chunk_index = config.eval.ngram_two_pass_min_chunk_index

    cache = NgramEvalCache(
        max_order=config.eval.ngram_eval_max_order,
        min_order=config.eval.ngram_eval_min_order,
        num_buckets=config.eval.ngram_eval_buckets,
        min_count=config.eval.ngram_eval_min_count,
    )

    model.eval()
    start = time.perf_counter()
    segments = _build_sliding_segments(total_tokens, seq_len, stride)

    # Pre-compute chunk ranges and their segment index ranges
    chunk_ranges: list[tuple[int, int]] = []
    seg_index_ranges: list[tuple[int, int]] = []
    seg_idx = 0
    for chunk_start in range(1, total_tokens + 1, chunk_tokens):
        chunk_end = min(chunk_start + chunk_tokens, total_tokens + 1)
        seg_start = seg_idx
        while seg_idx < len(segments) and segments[seg_idx][4] < chunk_end:
            seg = segments[seg_idx]
            if seg[4] < chunk_start or seg[5] > chunk_end:
                raise ValueError(
                    "NGRAM_EVAL_CHUNK_TOKENS does not align with the sliding scorer's target segments"
                )
            seg_idx += 1
        chunk_ranges.append((chunk_start, chunk_end))
        seg_index_ranges.append((seg_start, seg_idx))

    if seg_idx != len(segments):
        raise ValueError(f"Processed {seg_idx} N-gram segments, expected {len(segments)}")

    n_chunks = len(chunk_ranges)
    master = rank == 0

    # ---- PASS 1: Standard score-first eval (builds full cache) ----
    if master:
        pass1_start = time.perf_counter()
    pass1_results = _score_chunks_ngram(
        config, model, rank, world_size, device, val_tokens, tokens_np, luts,
        cache, segments, chunk_ranges, seg_index_ranges, seq_len,
        update_cache=True,
    )
    if master:
        pass1_ms = 1000.0 * (time.perf_counter() - pass1_start)

    # Compute pass-1 totals and per-chunk BPBs for logging
    total_loss = sum(r[0] for r in pass1_results)
    total_bytes = sum(r[1] for r in pass1_results)
    total_toks = sum(r[2] for r in pass1_results)
    pass1_bpb = (total_loss / math.log(2.0)) / max(total_bytes, 1.0)

    if master:
        # Log per-chunk BPB for first and last few chunks
        for ci in list(range(min(5, n_chunks))) + list(range(max(n_chunks - 3, 5), n_chunks)):
            cl, cb, ct = pass1_results[ci]
            cbpb = (cl / math.log(2.0)) / max(cb, 1.0) if cb > 0 else 0.0
            tag = "COLD" if ci < rescore_n else "warm"
            print(f"  ngram_pass1 chunk:{ci+1}/{n_chunks} bpb:{cbpb:.4f} [{tag}]", flush=True)
        print(f"  ngram_pass1_total bpb:{pass1_bpb:.4f} time:{pass1_ms:.0f}ms", flush=True)

    pass1_chunk_bpbs = [
        ((cl / math.log(2.0)) / max(cb, 1.0)) if cb > 0 else 0.0
        for cl, cb, _ in pass1_results
    ]

    def _select_rescore_chunk_indices() -> list[int]:
        eligible = list(range(min(pass2_min_chunk_index, n_chunks), n_chunks))
        if not eligible:
            return []
        k = min(rescore_n, len(eligible))
        if pass2_policy == "prefix":
            return eligible[:k]
        if pass2_policy == "top_bpb":
            ranked = sorted(eligible, key=lambda ci: (-pass1_chunk_bpbs[ci], ci))
            return sorted(ranked[:k])
        if pass2_policy == "top_delta_proxy":
            # Prefer chunks with large cold-cache penalty proxy: high pass-1 bpb,
            # but de-prioritize the very hottest prefix-only heuristic by also
            # rewarding proximity to the warm-cache floor seen in late chunks.
            warm_floor = min(pass1_chunk_bpbs[max(n_chunks - 8, 0):]) if n_chunks > 0 else 0.0
            ranked = sorted(
                eligible,
                key=lambda ci: (-(pass1_chunk_bpbs[ci] - warm_floor), -pass1_chunk_bpbs[ci], ci),
            )
            return sorted(ranked[:k])
        raise ValueError(f"unsupported pass2 policy: {pass2_policy}")

    # ---- PASS 2: Rescore early chunks with full cache ----
    if two_pass and rescore_n > 0:
        rescore_indices = _select_rescore_chunk_indices()
        actual_rescore = len(rescore_indices)
        if master:
            pass2_start = time.perf_counter()
            pretty = ",".join(str(ci + 1) for ci in rescore_indices[:24])
            suffix = "..." if len(rescore_indices) > 24 else ""
            print(
                f"  ngram_pass2: policy={pass2_policy} rescoring {actual_rescore} chunks "
                f"(indices:{pretty}{suffix}) with full cache ({n_chunks} chunks seen)...",
                flush=True,
            )

        rescore_ranges = [chunk_ranges[ci] for ci in rescore_indices]
        rescore_seg_ranges = [seg_index_ranges[ci] for ci in rescore_indices]

        pass2_results = _score_chunks_ngram(
            config, model, rank, world_size, device, val_tokens, tokens_np, luts,
            cache, segments, rescore_ranges, rescore_seg_ranges, seq_len,
            update_cache=False,  # DO NOT modify cache in pass 2
        )

        if master:
            pass2_ms = 1000.0 * (time.perf_counter() - pass2_start)

        # Replace early chunk scores with pass-2 scores
        for local_idx, ci in enumerate(rescore_indices):
            old_loss, old_bytes, old_toks = pass1_results[ci]
            new_loss, new_bytes, new_toks = pass2_results[local_idx]
            total_loss = total_loss - old_loss + new_loss
            total_bytes = total_bytes - old_bytes + new_bytes
            # token count stays the same (same tokens scored)

            if master:
                old_bpb = (old_loss / math.log(2.0)) / max(old_bytes, 1.0) if old_bytes > 0 else 0.0
                new_bpb = (new_loss / math.log(2.0)) / max(new_bytes, 1.0) if new_bytes > 0 else 0.0
                delta = old_bpb - new_bpb
                print(f"  ngram_pass2 chunk:{ci+1} pass1:{old_bpb:.4f} pass2:{new_bpb:.4f} delta:{delta:+.4f}", flush=True)

        pass2_bpb = (total_loss / math.log(2.0)) / max(total_bytes, 1.0)
        if master:
            improvement = pass1_bpb - pass2_bpb
            print(f"  ngram_pass2_total bpb:{pass2_bpb:.4f} improvement:{improvement:+.4f} time:{pass2_ms:.0f}ms", flush=True)

    val_loss = total_loss / max(total_toks, 1)
    val_bpb = (total_loss / math.log(2.0)) / max(total_bytes, 1.0)
    return EvalResult(
        val_loss=val_loss,
        val_bpb=val_bpb,
        eval_ms=1000.0 * (time.perf_counter() - start),
        stride=stride,
        eval_seq_len=seq_len,
    )


def eval_standard(
    config: ExperimentConfig,
    model: nn.Module,
    rank: int,
    world_size: int,
    device: torch.device,
    grad_accum_steps: int,
    val_tokens: Tensor,
    luts: tuple[Tensor, Tensor, Tensor],
    *,
    eval_seq_len: int | None = None,
) -> EvalResult:
    seq_len = eval_seq_len or config.eval.eval_seq_len or config.train.train_seq_len
    local_batch_tokens = config.train.val_batch_size // (world_size * grad_accum_steps)
    if local_batch_tokens < seq_len:
        raise ValueError("VAL_BATCH_SIZE must provide at least one sequence per rank")
    local_batch_seqs = local_batch_tokens // seq_len
    total_seqs = (val_tokens.numel() - 1) // seq_len
    seq_start = (total_seqs * rank) // world_size
    seq_end = (total_seqs * (rank + 1)) // world_size
    val_loss_sum = torch.zeros((), device=device, dtype=torch.float64)
    val_token_count = torch.zeros((), device=device, dtype=torch.float64)
    val_byte_count = torch.zeros((), device=device, dtype=torch.float64)
    was_training = model.training
    start = time.perf_counter()
    model.eval()
    with torch.inference_mode():
        for batch_seq_start in range(seq_start, seq_end, local_batch_seqs):
            batch_seq_end = min(batch_seq_start + local_batch_seqs, seq_end)
            raw_start = batch_seq_start * seq_len
            raw_end = batch_seq_end * seq_len + 1
            local = val_tokens[raw_start:raw_end].to(device=device, dtype=torch.int64, non_blocking=True)
            x = local[:-1].reshape(-1, seq_len)
            y = local[1:].reshape(-1, seq_len)
            with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                batch_loss = model(x, y).detach()
            token_count = float(y.numel())
            val_loss_sum += batch_loss.to(torch.float64) * token_count
            val_token_count += token_count
            token_bytes = _score_token_bytes(x.reshape(-1), y.reshape(-1), luts)
            val_byte_count += token_bytes.to(torch.float64).sum()
    if dist.is_available() and dist.is_initialized():
        dist.all_reduce(val_loss_sum, op=dist.ReduceOp.SUM)
        dist.all_reduce(val_token_count, op=dist.ReduceOp.SUM)
        dist.all_reduce(val_byte_count, op=dist.ReduceOp.SUM)
    if was_training:
        model.train()
    val_loss = float((val_loss_sum / val_token_count).item())
    bits_per_token = val_loss / math.log(2.0)
    tokens_per_byte = val_token_count.item() / val_byte_count.item()
    return EvalResult(
        val_loss=val_loss,
        val_bpb=float(bits_per_token * tokens_per_byte),
        eval_ms=1000.0 * (time.perf_counter() - start),
        eval_seq_len=seq_len,
    )


def eval_sliding(
    config: ExperimentConfig,
    model: nn.Module,
    device: torch.device,
    val_tokens: Tensor,
    luts: tuple[Tensor, Tensor, Tensor],
    *,
    stride: int | None = None,
    eval_seq_len: int | None = None,
) -> EvalResult:
    seq_len = eval_seq_len or config.eval.eval_seq_len or config.train.train_seq_len
    stride = stride or config.eval.sliding_stride
    total_tokens = val_tokens.numel() - 1
    segments = _build_sliding_segments(total_tokens, seq_len, stride)
    loss_sum = torch.zeros((), device=device, dtype=torch.float64)
    token_count = torch.zeros((), device=device, dtype=torch.float64)
    byte_count = torch.zeros((), device=device, dtype=torch.float64)
    was_training = model.training
    start = time.perf_counter()
    model.eval()
    # Use the model's forward_logits directly — if model was already torch.compile'd
    # by ensure_export_eval_model(), this goes through the compiled path automatically.
    # No need for a separate compilation of forward_logits.
    forward_logits = model.forward_logits
    with torch.inference_mode():
        for batch_idx in range(0, len(segments), config.eval.eval_batch_seqs):
            batch_segments = segments[batch_idx : batch_idx + config.eval.eval_batch_seqs]
            batch_size = len(batch_segments)
            x_batch = torch.zeros(batch_size, seq_len, dtype=torch.int64, device=device)
            y_batch = torch.zeros(batch_size, seq_len, dtype=torch.int64, device=device)
            for row_idx, (window_start, valid_len, _, _, _, _) in enumerate(batch_segments):
                end = min(window_start + seq_len, total_tokens)
                chunk = val_tokens[window_start : end + 1].to(device=device, dtype=torch.int64)
                x_batch[row_idx, :valid_len] = chunk[:-1]
                y_batch[row_idx, :valid_len] = chunk[1:]
            with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=device.type == "cuda"):
                logits = forward_logits(x_batch)
            for row_idx, (_, _, score_start, score_end, _, _) in enumerate(batch_segments):
                nll = F.cross_entropy(
                    logits[row_idx, score_start:score_end].float(),
                    y_batch[row_idx, score_start:score_end],
                    reduction="sum",
                )
                count = score_end - score_start
                loss_sum += nll.to(torch.float64)
                token_count += count
                token_bytes = _score_token_bytes(
                    x_batch[row_idx, score_start:score_end].reshape(-1),
                    y_batch[row_idx, score_start:score_end].reshape(-1),
                    luts,
                )
                byte_count += token_bytes.to(torch.float64).sum()
    if was_training:
        model.train()
    val_loss = float((loss_sum / token_count).item())
    bits_per_token = val_loss / math.log(2.0)
    tokens_per_byte = token_count.item() / byte_count.item()
    return EvalResult(
        val_loss=val_loss,
        val_bpb=float(bits_per_token * tokens_per_byte),
        eval_ms=1000.0 * (time.perf_counter() - start),
        stride=stride,
        eval_seq_len=seq_len,
    )


def eval_doc_isolated(
    config: ExperimentConfig,
    model: nn.Module,
    device: torch.device,
    val_tokens: Tensor,
    luts: tuple[Tensor, Tensor, Tensor],
    *,
    bos_id: int,
) -> EvalResult:
    spans = _document_spans(val_tokens, bos_id)
    total_loss_nats = 0.0
    total_tokens = 0.0
    total_bytes = 0.0
    start = time.perf_counter()
    for doc_start, doc_end in spans:
        doc_tokens = val_tokens[doc_start : doc_end + 1]
        doc_result = eval_sliding(config, model, device, doc_tokens, luts)
        total_loss_nats += doc_result.val_loss * (doc_tokens.numel() - 1)
        total_tokens += doc_tokens.numel() - 1
        total_bytes += (doc_result.val_loss / math.log(2.0)) / doc_result.val_bpb * (doc_tokens.numel() - 1)
    val_loss = total_loss_nats / max(total_tokens, 1.0)
    bits_per_token = val_loss / math.log(2.0)
    tokens_per_byte = total_tokens / max(total_bytes, 1.0)
    return EvalResult(
        val_loss=float(val_loss),
        val_bpb=float(bits_per_token * tokens_per_byte),
        eval_ms=1000.0 * (time.perf_counter() - start),
        stride=config.eval.sliding_stride,
        eval_seq_len=config.eval.eval_seq_len,
        doc_isolated=True,
    )


def classify_tensor(name: str) -> tuple[str, str]:
    if name.startswith("tok_emb"):
        return "lexical", "embedding"
    if name.startswith("bigram"):
        if ".embed" in name:
            return "lexical", "embedding"
        return "lexical", "control"
    if name.startswith("smear"):
        return "lexical", "control"
    if name.startswith("ve_shared"):
        if ".embed" in name:
            return "value_embedding", "embedding"
        return "value_embedding", "control"
    if name.startswith("ve_layer_scales"):
        return "value_embedding", "control"
    if name.startswith("skip_weights"):
        return "skip", "control"
    if name.startswith("lower_shared_blocks"):
        if "dw_weight" in name or "mix_proj" in name:
            return "local_lower", "local_mixer"
        if ".mlp." in name:
            return "local_lower", "mlp"
        return "local_lower", "control"
    if name.startswith("upper_blocks"):
        if ".attn." in name:
            return "upper_global", "attention"
        if ".mlp." in name:
            return "upper_global", "mlp"
        return "upper_global", "control"
    if name.startswith("final_norm"):
        return "output", "control"
    if name.startswith("lm_head"):
        return "output", "embedding"
    return "other", "other"


def _quant_bounds(bits: int) -> tuple[int, int]:
    qmax = (1 << (bits - 1)) - 1
    return -qmax, qmax


def _quantize_int8_per_row(tensor: Tensor, clip_percentile: float) -> tuple[Tensor, Tensor, dict[str, Any]]:
    t32 = tensor.float()
    clip_q = clip_percentile / 100.0
    if t32.ndim == 2:
        clip_abs = torch.quantile(t32.abs(), clip_q, dim=1) if t32.numel() else torch.empty((t32.shape[0],))
        clipped = torch.maximum(torch.minimum(t32, clip_abs[:, None]), -clip_abs[:, None])
        scale = (clip_abs / 127.0).clamp_min(1.0 / 127.0).to(torch.float16)
        quant = torch.clamp(torch.round(clipped / scale.float()[:, None]), -127, 127).to(torch.int8)
        return quant.contiguous(), scale.contiguous(), {"clip_percentile": clip_percentile}
    clip_abs = float(torch.quantile(t32.abs().flatten(), clip_q).item()) if t32.numel() else 0.0
    scale = torch.tensor(clip_abs / 127.0 if clip_abs > 0 else 1.0, dtype=torch.float16)
    quant = torch.clamp(torch.round(torch.clamp(t32, -clip_abs, clip_abs) / scale.float()), -127, 127).to(torch.int8)
    return quant.contiguous(), scale, {"clip_percentile": clip_percentile}


def _quantize_int6_per_row(tensor: Tensor, clip_percentiles: tuple[float, ...]) -> tuple[Tensor, Tensor, dict[str, Any]]:
    t32 = tensor.float()
    if t32.ndim == 2:
        best_quant: Tensor | None = None
        best_scale: Tensor | None = None
        best_error = float("inf")
        best_percentile: float | None = None
        for percentile in clip_percentiles:
            row_clip = torch.quantile(t32.abs(), percentile, dim=1) if percentile < 1.0 else t32.abs().amax(dim=1)
            scale = (row_clip / 31.0).clamp_min(1.0 / 31.0)
            quant = torch.clamp(torch.round(t32 / scale[:, None]), -31, 31).to(torch.int8)
            recon = quant.float() * scale[:, None]
            error = (t32 - recon).pow(2).mean().item()
            if error < best_error:
                best_error = error
                best_percentile = percentile
                best_quant = quant.contiguous()
                best_scale = scale.to(torch.float16).contiguous()
        if best_quant is None or best_scale is None or best_percentile is None:
            raise RuntimeError("int6 quantization failed")
        return best_quant, best_scale, {"clip_histogram": {f"{best_percentile:.6f}": int(best_scale.numel())}}
    amax = t32.abs().max().item()
    scale = torch.tensor(amax / 31.0 if amax > 0 else 1.0, dtype=torch.float16)
    quant = torch.clamp(torch.round(t32 / scale.float()), -31, 31).to(torch.int8)
    return quant.contiguous(), scale, {"clip_histogram": {"1.000000": 1}}


def _find_best_row_scales(
    tensor: Tensor,
    *,
    clip_range: int,
    percentiles: tuple[float, ...],
) -> tuple[Tensor, dict[str, int]]:
    t32 = tensor.float()
    if t32.ndim != 2:
        amax = t32.abs().max().item() if t32.numel() else 0.0
        scale = torch.tensor(amax / clip_range if amax > 0 else 1.0, dtype=torch.float16)
        return scale, {"1.000000": 1}

    best_scale = (t32.abs().amax(dim=1) / clip_range).clamp_min(1.0 / clip_range)
    best_err = torch.full((t32.shape[0],), float("inf"), dtype=torch.float32)
    best_choice = torch.full((t32.shape[0],), len(percentiles) - 1, dtype=torch.int64)
    for idx, percentile in enumerate(percentiles):
        if percentile < 1.0:
            row_clip = torch.quantile(t32.abs(), percentile, dim=1)
        else:
            row_clip = t32.abs().amax(dim=1)
        scale = (row_clip / clip_range).clamp_min(1.0 / clip_range)
        quant = torch.clamp(torch.round(t32 / scale[:, None]), -clip_range, clip_range)
        recon = quant * scale[:, None]
        err = (t32 - recon).pow(2).mean(dim=1)
        improved = err < best_err
        best_scale[improved] = scale[improved]
        best_err[improved] = err[improved]
        best_choice[improved] = idx

    histogram: dict[str, int] = {}
    for idx, percentile in enumerate(percentiles):
        count = int((best_choice == idx).sum().item())
        if count > 0:
            histogram[f"{percentile:.6f}"] = count
    return best_scale.to(torch.float16).contiguous(), histogram


def gptq_calibrate(
    model: nn.Module,
    train_pattern: str,
    device: torch.device,
    *,
    n_samples: int = 256,
    seq_len: int = 2048,
    batch_tokens: int | None = None,
    rank: int = 0,
    world_size: int = 1,
) -> dict[str, Tensor]:
    """Collect Hessian H = X^T X for each CastedLinear layer using training data."""
    hessians: dict[str, Tensor] = {}
    n_seen: dict[str, int] = {}
    hooks: list[Any] = []
    modules: list[tuple[str, nn.Module]] = [
        (name, module)
        for name, module in model.named_modules()
        if isinstance(module, CastedLinear) and getattr(module, "weight", None) is not None and module.weight.ndim == 2
    ]
    calib_device = device if device.type == "cuda" else torch.device("cpu")
    for name, module in modules:
        cols = int(module.weight.shape[1])
        hessians[name] = torch.zeros((cols, cols), dtype=torch.float32, device=calib_device)
        n_seen[name] = 0

    def make_hook(name: str):
        def hook_fn(module: nn.Module, inp: tuple, out: Any) -> None:
            x = inp[0].detach().float()
            if x.ndim == 3:
                x = x.reshape(-1, x.shape[-1])
            hessians[name].addmm_(x.t(), x)
            n_seen[name] += x.shape[0]

        return hook_fn

    for name, module in modules:
        hooks.append(module.register_forward_hook(make_hook(name)))

    grad_accum_steps = max(1, 8 // max(world_size, 1))
    loader: DistributedTokenLoader | None = None
    stream: TokenStream | None = None
    if batch_tokens is not None and batch_tokens > 0:
        loader = DistributedTokenLoader(train_pattern, rank, world_size, device)
    else:
        stream = TokenStream(train_pattern)
    model.eval()
    autocast_enabled = device.type == "cuda"
    with torch.inference_mode():
        for _ in range(n_samples):
            if loader is not None:
                x, _ = loader.next_batch(batch_tokens, seq_len, grad_accum_steps)
            else:
                assert stream is not None
                tokens = stream.take(seq_len + 1).to(device=device, dtype=torch.int64)
                x = tokens[:-1].unsqueeze(0)
            with torch.autocast(device_type="cuda", dtype=torch.bfloat16, enabled=autocast_enabled):
                model.forward_logits(x)
    for h in hooks:
        h.remove()
    for name in hessians:
        hessians[name] /= max(n_seen[name], 1)
        if hessians[name].device.type != "cpu":
            hessians[name] = hessians[name].cpu()
    return hessians


def gptq_quantize_weight(
    W: Tensor,
    H: Tensor,
    clip_range: int = 15,
    block_size: int = 128,
    percdamp: float = 0.01,
    scale_percentiles: tuple[float, ...] = (0.9990, 0.9995, 0.9999, 0.99999, 1.0),
) -> tuple[Tensor, Tensor, dict[str, Any]]:
    """GPTQ: quantize weight W using Hessian H = X^T X for error compensation."""
    W = W.float().clone()
    rows, cols = W.shape
    row_scale, clip_histogram = _find_best_row_scales(W, clip_range=clip_range, percentiles=scale_percentiles)
    row_scale_f = row_scale.float()
    H = H.float().clone()
    dead = torch.diag(H) == 0
    if dead.any():
        H[dead, dead] = 1.0
    damp = percdamp * H.diag().mean()
    H.diagonal().add_(damp)
    perm = torch.argsort(H.diag(), descending=True)
    invperm = torch.argsort(perm)
    W = W[:, perm]
    if dead.any():
        W[:, dead[perm]] = 0
    H = H[perm][:, perm]
    try:
        Hinv = torch.cholesky_inverse(torch.linalg.cholesky(H))
        Hinv = torch.linalg.cholesky(Hinv, upper=True)
    except Exception:
        quant, scale, quant_stats = _quantize_gptq_style_per_row(
            W[:, invperm],
            bits=6 if clip_range > 15 else 5,
            refine_steps=1,
            damp_percent=percdamp,
            scale_percentiles=scale_percentiles,
        )
        quant_stats["quant_method"] = "gptq_fallback_per_row"
        quant_stats["block_size"] = block_size
        return quant, scale, quant_stats
    Q = torch.zeros(rows, cols, dtype=torch.int8)
    for i1 in range(0, cols, block_size):
        i2 = min(i1 + block_size, cols)
        W_block = W[:, i1:i2].clone()
        Hinv_block = Hinv[i1:i2, i1:i2]
        Err = torch.zeros_like(W_block)
        for j in range(i2 - i1):
            w_col = W_block[:, j]
            d = Hinv_block[j, j].clamp_min(1e-8)
            q_col = torch.clamp(torch.round(w_col / row_scale_f), -clip_range, clip_range)
            deq_col = q_col * row_scale_f
            Q[:, i1 + j] = q_col.to(torch.int8)
            err = (w_col - deq_col) / d
            Err[:, j] = err
            W_block[:, j:] -= err.unsqueeze(1) * Hinv_block[j, j:].unsqueeze(0)
        if i2 < cols:
            W[:, i2:] -= Err @ Hinv[i1:i2, i2:]
    Q = Q[:, invperm]
    return Q.contiguous(), row_scale.contiguous(), {
        "quant_method": "hessian_gptq",
        "block_size": block_size,
        "percdamp": percdamp,
        "actorder": "descending_diag",
        "clip_histogram": clip_histogram,
    }


def _quantize_gptq_style_per_row(
    tensor: Tensor,
    *,
    bits: int,
    refine_steps: int,
    damp_percent: float,
    scale_percentiles: tuple[float, ...] = (0.9990, 0.9995, 0.9999, 0.99999, 1.0),
) -> tuple[Tensor, Tensor, dict[str, Any]]:
    t32 = tensor.float()
    qmin, qmax = _quant_bounds(bits)
    if t32.ndim != 2:
        amax = t32.abs().max().item()
        scale = torch.tensor(amax / qmax if amax > 0 else 1.0, dtype=torch.float16)
        quant = torch.clamp(torch.round(t32 / scale.float()), qmin, qmax).to(torch.int8)
        return quant.contiguous(), scale, {"quant_bits": bits, "refine_steps": refine_steps}

    quant_rows: list[Tensor] = []
    scale_rows: list[Tensor] = []
    best_scales, clip_histogram = _find_best_row_scales(t32, clip_range=qmax, percentiles=scale_percentiles)
    for row, initial_scale in zip(t32, best_scales.float(), strict=True):
        scale = initial_scale
        q = torch.zeros_like(row)
        for _ in range(max(refine_steps, 1)):
            q = torch.clamp(torch.round(row / scale), qmin, qmax)
            denom = q.float().square().sum()
            damp = max(float(row.numel()), 1.0) * damp_percent
            denom = denom + damp
            scale = (row * q.float()).sum().abs().div(denom).clamp_min(1.0 / qmax)
        quant_rows.append(q.to(torch.int8))
        scale_rows.append(scale.to(torch.float16).reshape(1))
    quant = torch.stack(quant_rows).contiguous()
    scale = torch.cat(scale_rows).contiguous()
    return quant, scale, {
        "quant_bits": bits,
        "refine_steps": refine_steps,
        "damp_percent": damp_percent,
        "clip_histogram": clip_histogram,
    }


def _reconstruct_tensor(storage: str, quant: Tensor | None, scale: Tensor | None, passthrough: Tensor | None, dtype: torch.dtype) -> Tensor:
    if storage.startswith("passthrough"):
        if passthrough is None:
            raise ValueError("passthrough tensor missing")
        out = passthrough
        if out.dtype != dtype:
            out = out.to(dtype=dtype)
        return out.contiguous()
    if quant is None or scale is None:
        raise ValueError("quantized tensor missing")
    if scale.ndim > 0:
        return (quant.float() * scale.float().view(quant.shape[0], *([1] * (quant.ndim - 1)))).to(dtype=dtype).contiguous()
    return (quant.float() * float(scale.item())).to(dtype=dtype).contiguous()


def _torch_save_bytes(obj: Any) -> bytes:
    buf = io.BytesIO()
    torch.save(obj, buf)
    return buf.getvalue()


def _merge_grouped_payload(grouped_payload: dict[str, dict[str, Tensor]]) -> dict[str, Tensor]:
    merged: dict[str, Tensor] = {}
    for subsystem in sorted(grouped_payload):
        for name in sorted(grouped_payload[subsystem]):
            merged[name] = grouped_payload[subsystem][name]
    return merged


def quantize_for_export(
    state_dict: dict[str, Tensor],
    config: ExportConfig,
    hessians: dict[str, Tensor] | None = None,
) -> tuple[dict[str, dict[str, Tensor]], dict[str, Any], dict[str, Any]]:
    grouped_payload: dict[str, dict[str, Tensor]] = defaultdict(dict)
    tensor_manifest: dict[str, dict[str, Any]] = {}
    stats: dict[str, Any] = {
        "raw_bytes_by_subsystem": defaultdict(int),
        "raw_bytes_by_tensor_class": defaultdict(int),
        "source_bytes": 0,
        "stored_bytes": 0,
        "tensor_stats": {},
        "gptq_layers": 0,
        "naive_layers": 0,
        "mixed_precision_params": {"int5": 0, "int6": 0},
    }
    upper_block_indices = [
        int(name.split(".")[1])
        for name in state_dict
        if name.startswith("upper_blocks.") and len(name.split(".")) > 2 and name.split(".")[1].isdigit()
    ]
    upper_int6_start = None
    if upper_block_indices and config.gptq_int6_last_n > 0:
        max_block_index = max(upper_block_indices)
        upper_int6_start = max(max_block_index - config.gptq_int6_last_n + 1, 0)

    for name, tensor in state_dict.items():
        tensor_cpu = tensor.detach().cpu().contiguous()
        subsystem, tensor_class = classify_tensor(name)
        if subsystem == "other" or tensor_class == "other":
            raise ValueError(f"Unclassified tensor in export path: {name}")
        stats["source_bytes"] += tensor_nbytes(tensor_cpu)
        storage = "passthrough"
        quant: Tensor | None = None
        scale: Tensor | None = None
        passthrough: Tensor | None = None
        quant_stats: dict[str, Any] = {}

        if not tensor_cpu.is_floating_point():
            passthrough = tensor_cpu
            storage = "passthrough_int"
        elif any(pattern in name for pattern in config.fp32_name_patterns):
            passthrough = tensor_cpu.float()
            storage = "passthrough_fp32"
        elif any(pattern in name for pattern in config.fp16_name_patterns):
            passthrough = tensor_cpu.to(torch.float16)
            storage = "passthrough_fp16"
        elif tensor_cpu.numel() <= config.keep_float_max_numel:
            passthrough = tensor_cpu.to(torch.float16)
            storage = "passthrough_small"
        elif tensor_class in config.int6_tensor_classes and config.export_quantizer == "rowclip_int6":
            quant, scale, quant_stats = _quantize_int6_per_row(tensor_cpu, config.int6_clip_percentiles)
            storage = "int6_per_row"
        elif tensor_class in config.int6_tensor_classes and config.export_quantizer == "full_gptq_int6":
            module_name = name.rsplit(".weight", 1)[0] if name.endswith(".weight") else name
            H = hessians.get(module_name) if hessians else None
            if H is not None and tensor_cpu.ndim == 2:
                quant, scale, quant_stats = gptq_quantize_weight(
                    tensor_cpu,
                    H,
                    clip_range=31,
                    block_size=config.gptq_block_size,
                    percdamp=config.gptq_damp_percent,
                    scale_percentiles=config.gptq_scale_percentiles,
                )
                stats["gptq_layers"] += 1
            else:
                quant, scale, quant_stats = _quantize_gptq_style_per_row(
                    tensor_cpu,
                    bits=6,
                    refine_steps=config.gptq_refine_steps,
                    damp_percent=config.gptq_damp_percent,
                    scale_percentiles=config.gptq_scale_percentiles,
                )
                stats["naive_layers"] += 1
            storage = "gptq_int6_per_row"
        elif tensor_class in config.int6_tensor_classes and config.export_quantizer == "full_gptq_int5":
            clip_range = 15
            storage = "gptq_int5_per_row"
            if upper_int6_start is not None and name.startswith("upper_blocks."):
                block_index = int(name.split(".")[1])
                if block_index >= upper_int6_start:
                    clip_range = 31
                    storage = "gptq_int6_per_row"
            module_name = name.rsplit(".weight", 1)[0] if name.endswith(".weight") else name
            H = hessians.get(module_name) if hessians else None
            if H is not None and tensor_cpu.ndim == 2:
                quant, scale, quant_stats = gptq_quantize_weight(
                    tensor_cpu,
                    H,
                    clip_range=clip_range,
                    block_size=config.gptq_block_size,
                    percdamp=config.gptq_damp_percent,
                    scale_percentiles=config.gptq_scale_percentiles,
                )
                stats["gptq_layers"] += 1
            else:
                quant, scale, quant_stats = _quantize_gptq_style_per_row(
                    tensor_cpu,
                    bits=6 if clip_range > 15 else 5,
                    refine_steps=config.gptq_refine_steps,
                    damp_percent=config.gptq_damp_percent,
                    scale_percentiles=config.gptq_scale_percentiles,
                )
                stats["naive_layers"] += 1
        else:
            quant, scale, quant_stats = _quantize_int8_per_row(tensor_cpu, config.int8_clip_percentile)
            storage = "int8_per_row"

        stored_bytes = 0
        if passthrough is not None:
            grouped_payload[subsystem][name] = passthrough
            stored_bytes += tensor_nbytes(passthrough)
        else:
            grouped_payload[subsystem][name + ".q"] = quant
            grouped_payload[subsystem][name + ".scale"] = scale
            stored_bytes += tensor_nbytes(quant) + tensor_nbytes(scale)
            if storage == "gptq_int5_per_row":
                stats["mixed_precision_params"]["int5"] += int(quant.numel())
            elif storage in {"gptq_int6_per_row", "int6_per_row"}:
                stats["mixed_precision_params"]["int6"] += int(quant.numel())

        recon = _reconstruct_tensor(storage, quant, scale, passthrough, tensor_cpu.dtype)
        if tensor_cpu.numel() == 0:
            mse = 0.0
            cosine = 1.0
        else:
            mse = (
                float((tensor_cpu.float() - recon.float()).pow(2).mean().item()) if tensor_cpu.is_floating_point() else 0.0
            )
            denom = tensor_cpu.float().norm() * recon.float().norm()
            cosine = float(((tensor_cpu.float() * recon.float()).sum() / denom).item()) if float(denom.item()) > 0 else 1.0
        tensor_manifest[name] = storage
        stats["stored_bytes"] += stored_bytes
        stats["raw_bytes_by_subsystem"][subsystem] += stored_bytes
        stats["raw_bytes_by_tensor_class"][tensor_class] += stored_bytes
        stats["tensor_stats"][name] = {
            "storage": storage,
            "mse": mse,
            "cosine": cosine,
            "stored_bytes": stored_bytes,
            "subsystem": subsystem,
            "tensor_class": tensor_class,
            "quant_stats": quant_stats,
        }

    metadata = {
        "format": "parameter_golf_research_export_v3_compact",
        "tensor_manifest": tensor_manifest,
    }
    stats["raw_bytes_by_subsystem"] = dict(sorted(stats["raw_bytes_by_subsystem"].items()))
    stats["raw_bytes_by_tensor_class"] = dict(sorted(stats["raw_bytes_by_tensor_class"].items()))
    return dict(grouped_payload), metadata, stats


def _compress_subsystem(subsystem: str, tensors: dict[str, Tensor], config: ExportConfig) -> tuple[str, int]:
    payload = {name: tensors[name] for name in sorted(tensors)}
    compressed = _compress_bytes(_torch_save_bytes({"payload": payload}), config)
    return subsystem, len(compressed)


def _collect_selective_pruning_rows(
    grouped_payload: dict[str, dict[str, Tensor]],
    metadata: dict[str, Any],
    config: ExportConfig,
) -> tuple[list[tuple[float, str, str, int, int]], int]:
    manifest = metadata.get("tensor_manifest", {})
    allowed_storage = set(config.selective_pruning_storage)
    candidates: list[tuple[float, str, str, int, int]] = []
    total_prunable = 0
    for base_name, storage in manifest.items():
        if storage not in allowed_storage:
            continue
        subsystem, tensor_class = classify_tensor(base_name)
        if subsystem == "other" or tensor_class == "other":
            continue
        quant_key = base_name + ".q"
        scale_key = base_name + ".scale"
        if subsystem not in grouped_payload or quant_key not in grouped_payload[subsystem] or scale_key not in grouped_payload[subsystem]:
            continue
        quant = grouped_payload[subsystem][quant_key]
        scale = grouped_payload[subsystem][scale_key]
        if quant.ndim != 2 or scale.ndim != 1 or scale.numel() != quant.shape[0]:
            continue
        pm_one = quant.abs() == 1
        counts = pm_one.sum(dim=1)
        for row_idx in (counts > 0).nonzero(as_tuple=False).flatten().tolist():
            count = int(counts[row_idx].item())
            total_prunable += count
            score = float(scale[row_idx].float().item()) ** 2
            candidates.append((score, subsystem, quant_key, row_idx, count))
    candidates.sort(key=lambda item: item[0])
    return candidates, total_prunable


def _refresh_subsystem_projection(
    grouped_payload: dict[str, dict[str, Tensor]],
    compressed_bytes_by_subsystem: dict[str, int],
    config: ExportConfig,
    subsystems: set[str],
) -> None:
    for subsystem in sorted(subsystems):
        _, nbytes = _compress_subsystem(subsystem, grouped_payload[subsystem], config)
        compressed_bytes_by_subsystem[subsystem] = nbytes


def _apply_selective_pruning(
    grouped_payload: dict[str, dict[str, Tensor]],
    metadata: dict[str, Any],
    config: ExportConfig,
    compressed_bytes_by_subsystem: dict[str, int],
    projected_limit: int,
) -> dict[str, Any] | None:
    if not config.selective_pruning_enabled:
        return None
    candidates, total_prunable = _collect_selective_pruning_rows(grouped_payload, metadata, config)
    if total_prunable <= 0:
        return None

    max_prunable = max(int(total_prunable * config.selective_pruning_max_fraction), 0)
    if max_prunable <= 0:
        return None

    def flush_pending_batch(
        pending_backups: list[tuple[Tensor, int, Tensor]],
        pending_subsystems: set[str],
        pending_rows: int,
        pending_values: int,
        last_projected_bytes: int,
    ) -> tuple[int, int, int, bool]:
        if not pending_backups:
            return last_projected_bytes, 0, 0, False
        _refresh_subsystem_projection(grouped_payload, compressed_bytes_by_subsystem, config, pending_subsystems)
        current_projected = int(sum(compressed_bytes_by_subsystem.values()))
        if current_projected < last_projected_bytes:
            return current_projected, pending_rows, pending_values, True
        for quant, row_idx, backup in pending_backups:
            quant[row_idx].copy_(backup)
        _refresh_subsystem_projection(grouped_payload, compressed_bytes_by_subsystem, config, pending_subsystems)
        return int(sum(compressed_bytes_by_subsystem.values())), 0, 0, False

    initial_projected = int(sum(compressed_bytes_by_subsystem.values()))
    pruned_rows = 0
    pruned_values = 0
    last_projected = initial_projected
    stagnant_batches = 0
    pending_backups: list[tuple[Tensor, int, Tensor]] = []
    pending_subsystems: set[str] = set()
    pending_rows = 0
    pending_values = 0

    for _, subsystem, quant_key, row_idx, _ in candidates:
        if pruned_values >= max_prunable:
            break
        quant = grouped_payload[subsystem][quant_key]
        row = quant[row_idx]
        mask = row.abs() == 1
        count = int(mask.sum().item())
        if count <= 0:
            continue
        pending_backups.append((quant, row_idx, row.clone()))
        row[mask] = 0
        pending_rows += 1
        pending_values += count
        pending_subsystems.add(subsystem)

        if pending_rows % config.selective_pruning_chunk_rows != 0:
            continue

        current_projected, committed_rows, committed_values, improved = flush_pending_batch(
            pending_backups,
            pending_subsystems,
            pending_rows,
            pending_values,
            last_projected,
        )
        if improved:
            stagnant_batches = 0
            pruned_rows += committed_rows
            pruned_values += committed_values
        else:
            stagnant_batches += 1
        last_projected = current_projected
        pending_backups.clear()
        pending_subsystems.clear()
        pending_rows = 0
        pending_values = 0
        if current_projected <= projected_limit or stagnant_batches >= 2:
            break

    if pending_backups:
        current_projected, committed_rows, committed_values, improved = flush_pending_batch(
            pending_backups,
            pending_subsystems,
            pending_rows,
            pending_values,
            last_projected,
        )
        if improved:
            pruned_rows += committed_rows
            pruned_values += committed_values
            last_projected = current_projected

    final_projected = int(sum(compressed_bytes_by_subsystem.values()))
    return {
        "enabled": True,
        "candidate_rows": len(candidates),
        "total_prunable_values": total_prunable,
        "max_prunable_values": max_prunable,
        "pruned_rows": pruned_rows,
        "pruned_values": pruned_values,
        "initial_projected_artifact_bytes": initial_projected,
        "final_projected_artifact_bytes": final_projected,
    }


def serialize_export_blob(
    grouped_payload: dict[str, dict[str, Tensor]],
    metadata: dict[str, Any],
    config: ExportConfig,
) -> tuple[bytes, dict[str, Any]]:
    compressed_bytes_by_subsystem: dict[str, int] = {}
    subsystems = sorted(grouped_payload)
    if len(subsystems) > 1:
        from concurrent.futures import ThreadPoolExecutor, as_completed
        with ThreadPoolExecutor(max_workers=min(len(subsystems), os.cpu_count() or 4)) as pool:
            futures = {
                pool.submit(_compress_subsystem, sub, grouped_payload[sub], config): sub
                for sub in subsystems
            }
            for future in as_completed(futures):
                sub, nbytes = future.result()
                compressed_bytes_by_subsystem[sub] = nbytes
    else:
        for subsystem in subsystems:
            _, nbytes = _compress_subsystem(subsystem, grouped_payload[subsystem], config)
            compressed_bytes_by_subsystem[subsystem] = nbytes
    projected_artifact_bytes = int(sum(compressed_bytes_by_subsystem.values()))
    projected_limit = config.submission_cap_bytes - config.projected_size_margin_bytes
    selective_pruning = None
    if projected_artifact_bytes > projected_limit:
        selective_pruning = _apply_selective_pruning(
            grouped_payload,
            metadata,
            config,
            compressed_bytes_by_subsystem,
            projected_limit,
        )
        projected_artifact_bytes = int(sum(compressed_bytes_by_subsystem.values()))
    if config.fail_fast_projected_size and projected_artifact_bytes > projected_limit:
        raise ValueError(
            "Projected compressed model exceeds submission cap margin: "
            f"{projected_artifact_bytes} > {projected_limit} "
            f"(cap={config.submission_cap_bytes} margin={config.projected_size_margin_bytes})"
        )
    merged_payload = _merge_grouped_payload(grouped_payload)
    blob = _compress_bytes(_torch_save_bytes({"payload": merged_payload}), config)
    artifact_stats = {
        "artifact_bytes": len(blob),
        "compressed_bytes_by_subsystem": dict(sorted(compressed_bytes_by_subsystem.items())),
        "projected_artifact_bytes": projected_artifact_bytes,
        "submission_cap_bytes": config.submission_cap_bytes,
        "projected_size_margin_bytes": config.projected_size_margin_bytes,
        "outer_metadata_bytes": 0,
        "sha256": hashlib.sha256(blob).hexdigest(),
    }
    if selective_pruning is not None:
        artifact_stats["selective_pruning"] = selective_pruning
    return blob, artifact_stats


def deserialize_export_blob(blob: bytes, config: ExportConfig) -> tuple[dict[str, dict[str, Tensor]], dict[str, Any], dict[str, Any]]:
    outer: dict[str, Any] | None = None
    raw_loaded = False
    try:
        candidate = torch.load(io.BytesIO(blob), map_location="cpu", weights_only=False)
        if isinstance(candidate, dict) and "subsystem_blobs" in candidate:
            outer = candidate
            raw_loaded = True
    except Exception:
        outer = None

    if raw_loaded and outer is not None:
        grouped_payload: dict[str, dict[str, Tensor]] = {}
        compressor = str(outer.get("compressor", config.normalized_compressor()))
        for subsystem, compressed in outer["subsystem_blobs"].items():
            inner = torch.load(
                io.BytesIO(_decompress_bytes(compressed, config, compressor=compressor)),
                map_location="cpu",
                weights_only=False,
            )
            grouped_payload[subsystem] = inner["payload"]
        artifact_stats = {
            "artifact_bytes": len(blob),
            "compressed_bytes_by_subsystem": {
                subsystem: len(compressed) for subsystem, compressed in outer["subsystem_blobs"].items()
            },
            "outer_metadata_bytes": len(blob) - sum(len(compressed) for compressed in outer["subsystem_blobs"].values()),
            "sha256": hashlib.sha256(blob).hexdigest(),
        }
        return grouped_payload, outer["metadata"], artifact_stats

    outer = torch.load(io.BytesIO(_decompress_bytes(blob, config)), map_location="cpu", weights_only=False)
    merged_payload = outer["payload"]
    grouped_payload = defaultdict(dict)
    for name, tensor in merged_payload.items():
        base_name = name.removesuffix(".q").removesuffix(".scale")
        subsystem, tensor_class = classify_tensor(base_name)
        if subsystem == "other" or tensor_class == "other":
            raise ValueError(f"Unclassified tensor in export artifact: {base_name}")
        grouped_payload[subsystem][name] = tensor

    compressed_bytes_by_subsystem: dict[str, int] = {}
    for subsystem in sorted(grouped_payload):
        payload = {name: grouped_payload[subsystem][name] for name in sorted(grouped_payload[subsystem])}
        compressed_bytes_by_subsystem[subsystem] = len(_compress_bytes(_torch_save_bytes({"payload": payload}), config))
    payload_only_blob = _compress_bytes(_torch_save_bytes({"payload": _merge_grouped_payload(grouped_payload)}), config)
    artifact_stats = {
        "artifact_bytes": len(blob),
        "compressed_bytes_by_subsystem": dict(sorted(compressed_bytes_by_subsystem.items())),
        "projected_artifact_bytes": len(payload_only_blob),
        "outer_metadata_bytes": 0,
        "sha256": hashlib.sha256(blob).hexdigest(),
    }
    return dict(grouped_payload), {"format": outer.get("format", "parameter_golf_research_export_v2_compact")}, artifact_stats


def dequantize_export(
    grouped_payload: dict[str, dict[str, Tensor]],
    metadata: dict[str, Any],
    template_state: dict[str, Tensor],
) -> dict[str, Tensor]:
    merged = _merge_grouped_payload(grouped_payload)
    output: dict[str, Tensor] = {}
    for name, template in template_state.items():
        if name in merged:
            output[name] = _reconstruct_tensor("passthrough", None, None, merged[name], template.dtype)
            continue
        quant_key = name + ".q"
        scale_key = name + ".scale"
        if quant_key in merged and scale_key in merged:
            output[name] = _reconstruct_tensor("quantized", merged[quant_key], merged[scale_key], None, template.dtype)
            continue
        raise KeyError(f"Missing exported tensor payload for {name}")
    return output


def partition_named_parameters(model: nn.Module) -> dict[str, list[tuple[str, nn.Parameter]]]:
    token_params: list[tuple[str, nn.Parameter]] = []
    matrix_params: list[tuple[str, nn.Parameter]] = []
    scalar_params: list[tuple[str, nn.Parameter]] = []
    head_params: list[tuple[str, nn.Parameter]] = []
    for name, param in model.named_parameters():
        if not param.requires_grad:
            continue
        if name.startswith("lm_head."):
            head_params.append((name, param))
            continue
        if name.startswith("tok_emb.") or name.startswith("bigram.embed.") or name.startswith("ve_shared.embed."):
            token_params.append((name, param))
            continue
        if param.ndim == 2 and not any(pattern in name for pattern in CONTROL_NAME_PATTERNS):
            matrix_params.append((name, param))
            continue
        scalar_params.append((name, param))
    return {
        "token": token_params,
        "matrix": matrix_params,
        "scalar": scalar_params,
        "head": head_params,
    }

