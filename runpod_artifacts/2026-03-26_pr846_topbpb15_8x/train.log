core_module = _sys.modules[__name__]


def _seed_everything(seed: int) -> None:
    random.seed(seed)
    np.random.seed(seed)
    torch.manual_seed(seed)
    if torch.cuda.is_available():
        torch.cuda.manual_seed_all(seed)


def _configure_cuda() -> None:
    torch.backends.cuda.matmul.allow_tf32 = True
    torch.backends.cudnn.allow_tf32 = True
    if torch.cuda.is_available():
        from torch.backends.cuda import enable_cudnn_sdp, enable_flash_sdp, enable_math_sdp, enable_mem_efficient_sdp

        enable_cudnn_sdp(False)
        enable_flash_sdp(True)
        enable_mem_efficient_sdp(False)
        enable_math_sdp(False)


def _build_logger(run_id: str, out_dir: str, master_process: bool):
    logfile = None
    if master_process:
        os.makedirs(out_dir, exist_ok=True)
        logfile = os.path.join(out_dir, f"{run_id}.txt")
        print(logfile)

    def log0(msg: str, console: bool = True) -> None:
        if not master_process:
            return
        if console:
            print(msg)
        if logfile is not None:
            with open(logfile, "a", encoding="utf-8") as handle:
                print(msg, file=handle)

    return log0, logfile


def _lr_mul(config: ExperimentConfig, step: int, elapsed_ms: float) -> float:
    if config.train.warmdown_iters <= 0:
        return 1.0
    max_wallclock_ms = 1000.0 * config.train.max_wallclock_seconds if config.train.max_wallclock_seconds > 0 else None
    if max_wallclock_ms is None:
        warmdown_start = max(config.train.iterations - config.train.warmdown_iters, 0)
        if warmdown_start <= step < config.train.iterations:
            return max((config.train.iterations - step) / max(config.train.warmdown_iters, 1), 0.0)
        return 1.0
    step_ms = elapsed_ms / max(step, 1)
    warmdown_ms = config.train.warmdown_iters * step_ms
    remaining_ms = max(max_wallclock_ms - elapsed_ms, 0.0)
    if remaining_ms <= warmdown_ms:
        return remaining_ms / max(warmdown_ms, 1e-9)
    return 1.0


def _measure_phase_ms(phase_timings: dict[str, Any], key: str, fn):
    torch.cuda.synchronize()
    start = time.perf_counter()
    result = fn()
    torch.cuda.synchronize()
    phase_timings[key] = 1000.0 * (time.perf_counter() - start)
    return result


def main() -> None:
    config = ExperimentConfig.from_env()
    distributed = "RANK" in os.environ and "WORLD_SIZE" in os.environ
    rank = int(os.environ.get("RANK", "0"))
    world_size = int(os.environ.get("WORLD_SIZE", "1"))
    local_rank = int(os.environ.get("LOCAL_RANK", "0"))
    if world_size <= 0:
        raise ValueError(f"WORLD_SIZE must be positive, got {world_size}")
    if 8 % world_size != 0:
        raise ValueError(f"WORLD_SIZE={world_size} must divide 8 so grad_accum_steps stays integral")
    if distributed and config.train.enable_compile and config.train.qat_mode != "off":
        raise RuntimeError(
            "QAT_MODE!=off with ENABLE_COMPILE=1 under DDP is currently unsupported. "
            "Use QAT_MODE=off for the record run, or rerun with ENABLE_COMPILE=0 to debug QAT safely."
        )
    if config.eval.ttt_enabled and config.eval.ttt_chunk_size > config.eval.eval_seq_len:
        raise RuntimeError(
            "TTT_CHUNK_SIZE must be <= EVAL_SEQ_LEN in the current TTT implementation. "
            "Use RUN_PROFILE=full_8gpu_600s, set TTT_ENABLED=0, or lower TTT_CHUNK_SIZE before launching."
        )
    grad_accum_steps = 8 // world_size
    grad_scale = 1.0 / grad_accum_steps
    if not torch.cuda.is_available():
        raise RuntimeError("CUDA is required for research/train.py")
    device = torch.device("cuda", local_rank)
    torch.cuda.set_device(device)
    if distributed:
        dist.init_process_group(backend="nccl", device_id=device)
