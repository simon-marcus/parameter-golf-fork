    def __post_init__(self) -> None:
        _validate_choice("EXPORT_QUANTIZER", self.export_quantizer, VALID_EXPORT_QUANTIZERS)
        if self.gptq_block_size <= 0:
            raise ValueError("GPTQ_BLOCK_SIZE must be positive")
        if self.gptq_refine_steps <= 0:
            raise ValueError("GPTQ_REFINE_STEPS must be positive")
        if self.gptq_damp_percent < 0:
            raise ValueError("GPTQ_DAMP_PERCENT must be non-negative")
        if self.gptq_calib_batches <= 0:
            raise ValueError("GPTQ_CALIB_BATCHES must be positive")
        if self.gptq_calib_batch_tokens < 0:
            raise ValueError("GPTQ_CALIB_BATCH_TOKENS must be non-negative")
        if self.gptq_calib_seq_len < 0:
            raise ValueError("GPTQ_CALIB_SEQ_LEN must be non-negative")
        if self.gptq_int6_last_n < 0:
            raise ValueError("GPTQ_INT6_LAST_N must be non-negative")
        if not self.gptq_scale_percentiles:
            raise ValueError("GPTQ_SCALE_PERCENTILES must not be empty")
        for percentile in self.gptq_scale_percentiles:
            if not 0.0 < percentile <= 1.0:
                raise ValueError("GPTQ_SCALE_PERCENTILES values must be in (0, 1]")
        if self.selective_pruning_chunk_rows <= 0:
            raise ValueError("SELECTIVE_PRUNING_CHUNK_ROWS must be positive")
        if not 0.0 <= self.selective_pruning_max_fraction <= 1.0:
            raise ValueError("SELECTIVE_PRUNING_MAX_FRACTION must be in [0, 1]")

    def normalized_compressor(self) -> str:
        compressor = self.compressor.strip().lower()
        if compressor == "zstd":
            return "zstd"
        if compressor == "lzma":
            return "lzma"
        return "zlib"


