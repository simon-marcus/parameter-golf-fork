    _validate_choice("MODEL_PRESET", config.model_preset, VALID_MODEL_PRESETS)
    _validate_choice("RUN_PROFILE", config.run_profile, VALID_RUN_PROFILES)
    _validate_choice("ACTIVATION_MODE", config.model.activation_mode, VALID_ACTIVATION_MODES)
    _validate_choice("EMA_WARMUP_STYLE", config.train.ema_warmup_style, VALID_EMA_WARMUP_STYLES)
    _validate_choice("QAT_MODE", config.train.qat_mode, VALID_QAT_MODES)
    _validate_choice("TTT_OPTIMIZER", config.eval.ttt_optimizer, VALID_TTT_OPTIMIZERS)
    _validate_choice("TTT_LR_SCHEDULE", config.eval.ttt_lr_schedule, VALID_TTT_LR_SCHEDULES)
    _validate_choice("EXPORT_QUANTIZER", config.export.export_quantizer, VALID_EXPORT_QUANTIZERS)
    if config.eval.ngram_eval_enabled:
        if config.eval.ngram_eval_chunk_tokens < config.eval.eval_seq_len:
            raise ValueError("NGRAM_EVAL_CHUNK_TOKENS must be >= EVAL_SEQ_LEN")
        if (config.eval.ngram_eval_chunk_tokens - config.eval.eval_seq_len) % config.eval.sliding_stride != 0:
            raise ValueError(
                "NGRAM_EVAL_CHUNK_TOKENS must align with sliding segments: "
                "(NGRAM_EVAL_CHUNK_TOKENS - EVAL_SEQ_LEN) % EVAL_STRIDE must be 0"
            )
    config.train.qat_enabled = config.train.qat_mode != "off"
    config.train.late_qat_threshold = config.train.qat_start_threshold


@dataclass
class ExperimentConfig:
    model_preset: str = field(default_factory=lambda: _env_str("MODEL_PRESET", "control_reference").lower())
    run_profile: str = field(default_factory=lambda: _env_str("RUN_PROFILE", "").lower())
    data: DataConfig = field(default_factory=DataConfig)
    model: ModelConfig = field(default_factory=ModelConfig)
    train: TrainConfig = field(default_factory=TrainConfig)
    eval: EvalConfig = field(default_factory=EvalConfig)
    export: ExportConfig = field(default_factory=ExportConfig)

    @classmethod
    def from_env(cls, *, model_preset: str | None = None, run_profile: str | None = None) -> "ExperimentConfig":
        config = cls()
        if model_preset is not None:
            config.model_preset = model_preset
        if run_profile is not None:
            config.run_profile = run_profile
        _apply_model_preset(config)
        _apply_run_profile(config)
        _validate_config(config)
        return config

    def to_dict(self) -> dict[str, Any]:
        return asdict(self)

    def to_json(self) -> str:
        return json.dumps(self.to_dict(), indent=2, sort_keys=True)

