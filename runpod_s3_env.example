RUNPOD_S3_VOLUME_ID=gs27hsi4q0
RUNPOD_S3_DATACENTER=US-GA-2
RUNPOD_S3_ENDPOINT=https://s3api-us-ga-2.runpod.io/
# These must come from Runpod Settings -> S3 API Keys, not ordinary AWS creds.
AWS_ACCESS_KEY_ID="user_your_runpod_s3_access_key"
AWS_SECRET_ACCESS_KEY="rps_your_runpod_s3_secret"
AWS_RETRY_MODE=standard
AWS_MAX_ATTEMPTS=10
